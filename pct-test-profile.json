{
  "meta": {
    "id": "PCT",
    "name": "Patent Cooperation Treaty (International Application)",
    "code": "PCT",
    "continent": "Global",
    "office": "WIPO – International Bureau",
    "officeUrl": "https://www.wipo.int/pct/en",
    "applicationTypes": ["international"],
    "languages": ["en", "fr", "de", "es", "zh", "ja", "ru", "ar", "ko", "pt"],
    "version": 1,
    "status": "active",
    "inheritsFrom": null,
    "tags": ["international", "pct_style", "treaty"],
    "createdAt": "2025-01-01T00:00:00Z",
    "updatedAt": "2025-01-01T00:00:00Z"
  },
  "structure": {
    "defaultVariant": "standard",
    "variants": [
      {
        "id": "standard",
        "label": "Standard PCT International Application",
        "description": "PCT-style specification for an international patent application.",
        "sections": [
          {
            "id": "title",
            "label": "Title",
            "order": 1,
            "canonicalKeys": ["title"],
            "required": true,
            "group": "header",
            "maxLengthChars": 500,
            "ui": {
              "placeholder": "Enter a concise technical title",
              "helpText": "No trademarks, no word 'patent', technical subject-matter only."
            }
          },
          {
            "id": "cross_reference",
            "label": "Reference to Related Applications",
            "order": 2,
            "canonicalKeys": ["cross_reference", "priority_data"],
            "required": false,
            "group": "header",
            "ui": {
              "placeholder": "Indicate any priority or related applications (e.g., national, provisional).",
              "helpText": "Include application number, filing date, country/office, and relationship where applicable."
            }
          },
          {
            "id": "field",
            "label": "Technical Field",
            "order": 3,
            "canonicalKeys": ["technical_field"],
            "required": true,
            "group": "body",
            "ui": {
              "placeholder": "State the technical field of the invention.",
              "helpText": "1–3 sentences; identify the technical field without advantages or embodiments."
            }
          },
          {
            "id": "background",
            "label": "Background Art",
            "order": 4,
            "canonicalKeys": ["background_art"],
            "required": false,
            "group": "body",
            "ui": {
              "placeholder": "Describe relevant prior art and problems.",
              "helpText": "Explain known techniques and their limitations without conceding obviousness."
            }
          },
          {
            "id": "summary",
            "label": "Disclosure of Invention",
            "order": 5,
            "canonicalKeys": ["disclosure_of_invention"],
            "required": true,
            "group": "body",
            "ui": {
              "placeholder": "Provide a high-level disclosure of the invention.",
              "helpText": "Set out the solution to the technical problem and main inventive features in general terms."
            }
          },
          {
            "id": "brief_drawings",
            "label": "Brief Description of Drawings",
            "order": 6,
            "canonicalKeys": ["brief_description_of_drawings"],
            "required": false,
            "group": "body",
            "ui": {
              "placeholder": "List each figure briefly.",
              "helpText": "One line per figure: 'Fig. 1 is a schematic view of …'."
            }
          },
          {
            "id": "detailed_description",
            "label": "Mode(s) for Carrying Out the Invention",
            "order": 7,
            "canonicalKeys": ["modes_for_carrying_out_invention", "detailed_description"],
            "required": true,
            "group": "body",
            "ui": {
              "placeholder": "Provide a full detailed description of embodiments.",
              "helpText": "Describe at least one way of carrying out the invention in sufficient detail; reference drawings where relevant."
            }
          },
          {
            "id": "industrial_applicability",
            "label": "Industrial Applicability",
            "order": 8,
            "canonicalKeys": ["industrial_applicability"],
            "required": false,
            "group": "body",
            "ui": {
              "placeholder": "Explain how the invention can be used in industry.",
              "helpText": "1–3 sentences showing that the invention can be made or used in any kind of industry."
            }
          },
          {
            "id": "claims",
            "label": "Claims",
            "order": 9,
            "canonicalKeys": ["claims"],
            "required": true,
            "group": "claims",
            "ui": {
              "placeholder": "Independent and dependent claims.",
              "helpText": "One claim per numbered paragraph; ensure support in the description."
            }
          },
          {
            "id": "abstract",
            "label": "Abstract",
            "order": 10,
            "canonicalKeys": ["abstract"],
            "required": true,
            "group": "abstract",
            "ui": {
              "placeholder": "Short technical abstract.",
              "helpText": "≤150 words, technical only; no marketing, advantages, or claim-style phrasing."
            }
          }
        ]
      }
    ]
  },
  "rules": {
    "global": {
      "paragraphNumberingRequired": false,
      "maxPagesRecommended": 100,
      "allowEquations": true,
      "allowTables": true
    },
    "abstract": {
      "wordLimit": 150,
      "noBenefitsOrAdvantages": true,
      "noClaimLanguage": true,
      "singleParagraph": true
    },
    "claims": {
      "twoPartFormPreferred": false,
      "allowMultipleDependent": true,
      "prohibitMultipleDependentOnMultipleDependent": true,
      "preferredConnectors": ["comprising", "including"],
      "discouragedConnectors": ["consisting of"],
      "forbiddenPhrases": [],
      "maxIndependentClaimsBeforeExtraFee": 3,
      "maxTotalClaimsRecommended": 20,
      "allowReferenceNumeralsInClaims": true,
      "requireSupportInDescription": true,
      "unityStandard": "PCT_UNITY_OF_INVENTION"
    },
    "description": {
      "requireBestModeDisclosure": false,
      "avoidClaimLanguage": true,
      "allowReferenceNumerals": true,
      "requireEmbodimentSupportForAllClaims": true,
      "industrialApplicabilitySectionRequired": false
    },
    "drawings": {
      "requiredWhenApplicable": true,
      "paperSize": "A4",
      "colorAllowed": false,
      "lineStyle": "black_and_white_solid",
      "referenceNumeralsMandatoryWhenDrawings": true,
      "minReferenceTextSizePt": 8,
      "marginTopCm": 2.0,
      "marginBottomCm": 1.0,
      "marginLeftCm": 2.5,
      "marginRightCm": 1.5
    },
    "procedural": {
      "gracePeriodMonths": 0,
      "foreignFilingLicenseRequired": false,
      "idsRequired": false,
      "priorArtDisclosureThreshold": "any_relevant_to_novelty_or_inventive_step",
      "allowProvisionalPriority": true,
      "isInternationalPhase": true,
      "designatedStatesMode": "all_by_default"
    },
    "language": {
      "allowedLanguages": ["en", "fr", "de", "es", "zh", "ja", "ru", "ar", "ko", "pt"],
      "requiresOfficialTranslation": true
    },
    "sequenceListing": {
      "requiredIfSeqDisclosed": true,
      "format": "ST.26-XML",
      "allowLateFurnishing": true,
      "lateFurnishingNotes": "Late submission permitted until the international search is carried out; may incur fees depending on the Receiving Office.",
      "affectsFilingDate": false,
      "additionalFormatsAllowedForReference": ["PDF"]
    },
    "pageLayout": {
      "defaultPageSize": "A4",
      "allowedPageSizes": ["A4"],
      "minMarginTopCm": 2.0,
      "minMarginBottomCm": 1.0,
      "minMarginLeftCm": 2.0,
      "minMarginRightCm": 1.5,
      "recommendedFontFamily": "Times New Roman",
      "recommendedFontSizePt": 12,
      "recommendedLineSpacing": 1.5
    },
    "designatedStates": {
      "mode": "all_by_default",
      "totalStates": 157,
      "electionAllowed": true,
      "electionRequiredForChapterII": false,
      "chapterIIDeadlineMonths": 22,
      "notes": "All PCT contracting states are designated by default; Chapter II election is optional for international preliminary examination."
    }
  },
  "validation": {
    "sectionChecks": {
      "title": [
        {
          "id": "title_length_words",
          "type": "maxWords",
          "limit": 25,
          "severity": "warning",
          "message": "Title appears long; consider making it more concise."
        }
      ],
      "abstract": [
        {
          "id": "abstract_word_limit",
          "type": "maxWords",
          "limit": 150,
          "severity": "error",
          "message": "Abstract exceeds the 150 word limit."
        }
      ],
      "claims": [
        {
          "id": "claims_count_recommended",
          "type": "maxCount",
          "limit": 20,
          "severity": "warning",
          "message": "Number of claims exceeds recommended 20; international phase fees may increase."
        }
      ]
    },
    "crossSectionChecks": [
      {
        "id": "claims_supported_by_description",
        "type": "support",
        "from": "claims",
        "mustBeSupportedBy": ["detailed_description"],
        "severity": "error",
        "message": "Some claim elements may not be clearly supported in the mode(s) for carrying out the invention."
      },
      {
        "id": "abstract_consistent_with_claims",
        "type": "consistency",
        "from": "abstract",
        "mustBeConsistentWith": ["claims"],
        "severity": "warning",
        "message": "Abstract may describe features not clearly reflected in the independent claims."
      }
    ]
  },
  "prompts": {
    "baseStyle": {
      "tone": "technical, neutral, precise",
      "voice": "impersonal_third_person",
      "avoid": [
        "marketing language",
        "unsupported advantages",
        "overly legalistic phrasing"
      ]
    },
    "sections": {
      "title": {
        "instruction": "Draft a concise technical title for the international application.",
        "constraints": [
          "Do not exceed 500 characters.",
          "Do not use trademarks or the word 'patent'."
        ]
      },
      "field": {
        "instruction": "Draft the Technical Field section.",
        "constraints": [
          "Limit to 1–3 sentences.",
          "Identify the technical field without describing advantages or embodiments."
        ]
      },
      "background": {
        "instruction": "Draft the Background Art section.",
        "constraints": [
          "Describe relevant prior art and its limitations.",
          "Avoid explicit admissions that specific documents are prior art unless clearly intended.",
          "Do not state that the invention is obvious or trivial."
        ]
      },
      "summary": {
        "instruction": "Draft the Disclosure of Invention section.",
        "constraints": [
          "Set out the solution to the technical problem in general terms.",
          "Highlight key inventive features.",
          "Ensure consistency with the independent claims."
        ]
      },
      "detailed_description": {
        "instruction": "Draft the Mode(s) for Carrying Out the Invention section.",
        "constraints": [
          "Describe embodiments in sufficient detail for a skilled person to carry out the invention.",
          "Ensure each independent claim has at least one supporting embodiment.",
          "Reference drawings and reference numerals where applicable."
        ]
      },
      "industrial_applicability": {
        "instruction": "Draft the Industrial Applicability section.",
        "constraints": [
          "Explain how the invention can be made or used in industry.",
          "Limit to 1–3 sentences.",
          "Do not repeat detailed embodiments."
        ]
      },
      "claims": {
        "instruction": "Draft a full set of claims compliant with PCT practice and typical designated states.",
        "constraints": [
          "Use 'comprising' or similar open connectors where appropriate.",
          "Each dependent claim must reference a single prior claim.",
          "Claims must be fully supported by the description.",
          "Maintain unity of invention according to PCT standards."
        ]
      },
      "abstract": {
        "instruction": "Draft the Abstract section.",
        "constraints": [
          "No more than 150 words.",
          "Summarize the technical disclosure objectively.",
          "Do not mention advantages or commercial benefits.",
          "Do not use claim-style language."
        ]
      }
    }
  },
  "export": {
    "documentTypes": [
      {
        "id": "spec_pdf",
        "label": "PCT Specification PDF",
        "includesSections": [
          "title",
          "field",
          "background",
          "summary",
          "brief_drawings",
          "detailed_description",
          "industrial_applicability",
          "claims",
          "abstract"
        ],
        "pageSize": "A4",
        "lineSpacing": 1.5,
        "fontFamily": "Times New Roman",
        "fontSizePt": 12,
        "addPageNumbers": true,
        "addParagraphNumbers": false,
        "marginTopCm": 2.0,
        "marginBottomCm": 1.0,
        "marginLeftCm": 2.5,
        "marginRightCm": 1.5
      }
    ],
    "sectionHeadings": {
      "field": "TECHNICAL FIELD",
      "background": "BACKGROUND ART",
      "summary": "DISCLOSURE OF INVENTION",
      "brief_drawings": "BRIEF DESCRIPTION OF THE DRAWINGS",
      "detailed_description": "MODE(S) FOR CARRYING OUT THE INVENTION",
      "industrial_applicability": "INDUSTRIAL APPLICABILITY",
      "claims": "CLAIMS",
      "abstract": "ABSTRACT"
    }
  },
  "diagrams": {
    "requiredWhenApplicable": true,
    "supportedDiagramTypes": ["block", "flowchart", "schematic", "perspective_view"],
    "figureLabelFormat": "Fig. {number}",
    "autoGenerateReferenceTable": true,
    "diagramGenerationHints": {
      "block": "Use rectangles for components and arrows for data/control flow.",
      "flowchart": "Use standard flowchart symbols for processes, decisions, and flows.",
      "schematic": "Show functional relationships and reference numerals clearly.",
      "perspective_view": "Use where overall physical form is important for understanding."
    }
  },
  "crossChecks": {
    "enableSemanticCrossCheck": true,
    "checkList": [
      {
        "id": "drawings_vs_description",
        "description": "Ensure all reference numerals in drawings are explained in the mode(s) for carrying out the invention.",
        "from": "drawings",
        "mustBeExplainedIn": ["detailed_description"]
      },
      {
        "id": "claims_vs_drawings",
        "description": "Ensure key claimed elements appear in at least one figure when drawings are present.",
        "from": "claims",
        "mustBeShownIn": ["drawings"]
      }
    ]
  }
}
