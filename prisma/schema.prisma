  userId       String @map("user_id")
  sessionId    String @map("session_id") // Always session-specific (validation overrides shouldn't be global)
  jurisdiction String @default("*")
  sectionKey   String @map("section_key")

  // Override limits (null = use country default)
  customMaxWords Int? @map("custom_max_words")
  customMaxChars Int? @map("custom_max_chars")
