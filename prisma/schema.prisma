// === PRIOR ART SEARCH MODELS ===

enum PriorArtSearchMode {
  LLM
  MANUAL
}

enum PriorArtSearchStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  ARCHIVED
}

enum PriorArtQueryLabel {
  BROAD
  BASELINE
  NARROW
}

model PriorArtSearchBundle {
  id       String               @id @default(cuid())
  patentId String
  mode     PriorArtSearchMode
  status   PriorArtSearchStatus @default(DRAFT)

  // Input data
  briefRaw       String? // Raw invention brief (LLM mode)
  inventionBrief String // Processed brief (max 200 words)

  // Generated/Edited data (JSON schema validated)
  bundleData Json // Complete JSON bundle per SRS schema

  // Metadata
  createdBy  String
  approvedBy String?
  approvedAt DateTime?
  version    String    @default("v1.0") // Semantic versioning
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  patent        Patent                  @relation(fields: [patentId], references: [id], onDelete: Cascade)
  creator       User                    @relation("PriorArtBundleCreator", fields: [createdBy], references: [id])
  approver      User?                   @relation("PriorArtBundleApprover", fields: [approvedBy], references: [id])
  history       PriorArtSearchHistory[]
  queryVariants PriorArtQueryVariant[]
  runs          PriorArtRun[]

  @@map("prior_art_search_bundles")
}

model PriorArtSearchHistory {
  id           String   @id @default(cuid())
  bundleId     String
  action       String // BRIEF_SUBMITTED, LLM_GENERATED, EDITED, VALIDATION_FAILED, etc.
  userId       String
  timestamp    DateTime @default(now())
  previousData Json? // Previous state for diffing
  newData      Json? // New state for diffing
  notes        String? // Optional notes about the change

  bundle PriorArtSearchBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  user   User                 @relation(fields: [userId], references: [id])

  @@map("prior_art_search_history")
}

model PriorArtQueryVariant {
  id        String             @id @default(cuid())
  bundleId  String
  label     PriorArtQueryLabel
  query     String // The actual search query
  num       Int                @default(20) // Results per page
  page      Int                @default(1) // Starting page
  notes     String // Strategy notes
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  bundle PriorArtSearchBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@unique([bundleId, label])
  @@map("prior_art_query_variants")
}

// === PRIOR ART SEARCH EXECUTION MODELS ===

enum PriorArtRunStatus {
  RUNNING
  COMPLETED
  COMPLETED_WITH_WARNINGS
  FAILED
  CREDIT_EXHAUSTED
}

model PriorArtRun {
  id             String            @id @default(cuid())
  bundleId       String
  bundleHash     String // Hash of approved bundle for integrity
  approvedBundle Json // Frozen approved bundle data
  status         PriorArtRunStatus @default(RUNNING)

  // User and credit tracking
  userId          String
  creditsConsumed Int      @default(1) // Always 1 credit per search
  apiCallsMade    Int      @default(0) // Actual API calls made
  costEstimate    Decimal? @db.Decimal(10, 4)

  // Timing
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  bundle                PriorArtSearchBundle            @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  user                  User                            @relation(fields: [userId], references: [id])
  queryVariants         PriorArtQueryVariantExecution[]
  rawResults            PriorArtRawResult[]
  // unifiedResults removed - no longer needed
  variantHits           PriorArtVariantHit[]
  PriorArtUnifiedResult PriorArtUnifiedResult[]

  // Level 0 local-database screening
  level0Checked       Boolean               @default(false)
  level0Determination NoveltyDetermination?
  level0Results       Json?
  level0ReportUrl     String?

  @@map("prior_art_runs")
}

model PriorArtQueryVariantExecution {
  id           String             @id @default(cuid())
  runId        String
  label        PriorArtQueryLabel
  query        String // Actual query executed
  num          Int                @default(20)
  pageTarget   Int                @default(1)
  pageExecuted Int                @default(1)
  apiCalls     Int                @default(0) // API calls for this variant
  resultsCount Int                @default(0)
  executedAt   DateTime           @default(now())

  run PriorArtRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, label])
  @@map("prior_art_query_variant_executions")
}

model PriorArtRawResult {
  id         String   @id @default(cuid())
  runId      String
  variantId  String // PriorArtQueryVariantExecution.id
  pageNo     Int      @default(1)
  payload    Json // Raw SerpAPI response
  receivedAt DateTime @default(now())

  run PriorArtRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@map("prior_art_raw_results")
}

model PriorArtRawDetail {
  id                String   @id @default(cuid())
  publicationNumber String // Normalized patent number
  patentId          String // SerpAPI patent ID (patent/US123/en or scholar/...)
  payload           Json // Raw SerpAPI details response
  fetchedAt         DateTime @default(now())

  @@unique([publicationNumber, patentId])
  @@map("prior_art_raw_details")
}

model PriorArtPatent {
  publicationNumber String    @id
  title             String?
  abstract          String?
  language          String?
  publicationDate   DateTime?
  priorityDate      DateTime?
  filingDate        DateTime?

  // Arrays stored as JSONB for flexibility
  assignees String[] // JSON array in DB
  inventors String[] // JSON array in DB
  cpcs      String[] // JSON array in DB
  ipcs      String[] // JSON array in DB

  link    String?
  pdfLink String?
  extras  Json? // Additional fields

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt

  // Relations
  variantHits PriorArtVariantHit[]
  details     PriorArtPatentDetail?
  // unifiedResults removed - relationship no longer exists

  @@map("prior_art_patents")
}

model PriorArtVariantHit {
  id                String   @id @default(cuid())
  runId             String
  variantId         String // PriorArtQueryVariantExecution.id
  publicationNumber String
  rankInVariant     Int // Position in variant results
  snippet           String? // Search result snippet
  foundAt           DateTime @default(now())

  run    PriorArtRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  patent PriorArtPatent @relation(fields: [publicationNumber], references: [publicationNumber])

  @@unique([runId, variantId, publicationNumber])
  @@map("prior_art_variant_hits")
}

model PriorArtPatentDetail {
  publicationNumber     String   @id
  claims                Json? // Full claims as JSONB
  description           String?
  classifications       Json? // Structured classifications
  worldwideApplications Json? // Filing data
  events                Json? // Legal events
  legalEvents           Json? // Additional events
  citationsPatent       Json? // Patent citations
  citationsNPL          Json? // Non-patent literature citations
  pdfLink               String?
  fetchedAt             DateTime @default(now())

  patent PriorArtPatent @relation(fields: [publicationNumber], references: [publicationNumber])

  @@map("prior_art_patent_details")
}

enum PriorArtIntersectionType {
  NONE // Found in only one variant
  I2 // Found in any 2 variants
  I3 // Found in all 3 variants
}

model PriorArtUnifiedResult {
  id                String              @id @default(cuid())
  runId             String
  publicationNumber String // Keep existing field for backward compatibility
  contentType       PriorArtContentType @default(PATENT) // PATENT or SCHOLAR
  scholarIdentifier String? // Optional field for scholar content identifiers
  foundInVariants   String[] // Array of variant labels: ["BROAD", "BASELINE", "NARROW"]

  // Ranks in each variant (null if not found)
  rankBroad    Int?
  rankBaseline Int?
  rankNarrow   Int?

  intersectionType PriorArtIntersectionType
  score            Decimal                  @db.Decimal(5, 4) // 0.0000 to 1.0000
  shortlisted      Boolean                  @default(false)

  createdAt DateTime @default(now())

  run PriorArtRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  // patent relationship removed - handle in application logic based on contentType

  @@unique([runId, publicationNumber])
  @@map("prior_art_unified_results")
}

model PriorArtScholarContent {
  identifier    String   @id
  title         String?
  authors       String[] // Array of author names
  publication   String? // Journal/conference name
  year          Int?
  abstract      String?
  citationCount Int?
  link          String? // Link to the article
  pdfLink       String? // Link to PDF if available
  doi           String? // Digital Object Identifier
  source        String? // Google Scholar, IEEE, ACM, etc.
  fetchedAt     DateTime @default(now())

  @@map("prior_art_scholar_content")
}

// === LOCAL PATENT DATASET (e.g., Indian patents) ===
model LocalPatent {
  id                Int     @id @default(autoincrement())
  publicationNumber String  @unique
  kind              String?
  title             String
  abstract          String?
  abstractOriginal  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("local_patents")
}

// === NOVELTY ASSESSMENT MODELS ===

enum NoveltyAssessmentStatus {
  PENDING
  STAGE1_SCREENING
  STAGE1_COMPLETED
  STAGE2_ASSESSMENT
  STAGE2_COMPLETED
  NOVEL
  NOT_NOVEL
  DOUBT_RESOLVED
  FAILED
}

enum NoveltyDetermination {
  NOVEL
  NOT_NOVEL
  PARTIALLY_NOVEL // Some aspects novel, others not
  DOUBT // Requires further analysis
}

enum NoveltyAssessmentStage {
  STAGE1_SCREENING
  STAGE2_ASSESSMENT
}

model NoveltyAssessmentRun {
  id       String                  @id @default(cuid())
  patentId String
  runId    String? // Link to prior art run that provided intersecting patents
  userId   String
  status   NoveltyAssessmentStatus @default(PENDING)

  // Input data
  inventionSummary    Json // Invention summary (title, problem, solution)
  intersectingPatents Json // Array of {publicationNumber, title, abstract, relevance?}

  // Stage 1 results (screening)
  stage1CompletedAt DateTime?
  stage1Results     Json? // Array of {publicationNumber, relevance, determination, confidence}

  // Stage 2 results (detailed assessment)
  stage2CompletedAt DateTime?
  stage2Results     Json? // Array of {publicationNumber, determination, remarks, suggestions}

  // Final determination
  finalDetermination NoveltyDetermination?
  finalRemarks       String?
  finalSuggestions   String?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patent   Patent                     @relation(fields: [patentId], references: [id], onDelete: Cascade)
  user     User                       @relation(fields: [userId], references: [id])
  llmCalls NoveltyAssessmentLLMCall[]

  @@map("novelty_assessment_runs")
}

model NoveltyAssessmentLLMCall {
  id            String                 @id @default(cuid())
  assessmentId  String
  stage         NoveltyAssessmentStage
  taskCode      TaskCode
  prompt        String
  response      Json?
  tokensUsed    Int?
  modelClass    String?
  determination NoveltyDetermination?
  remarks       String?
  suggestions   String?
  calledAt      DateTime               @default(now())

  // Relations
  assessment NoveltyAssessmentRun @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("novelty_assessment_llm_calls")
}

enum PriorArtContentType {
  PATENT
  SCHOLAR
}

enum NoveltySearchStatus {
  PENDING
  STAGE_0_COMPLETED
  STAGE_1_COMPLETED
  STAGE_3_5_COMPLETED
  COMPLETED
  FAILED
}

enum NoveltySearchStage {
  STAGE_0
  STAGE_1
  STAGE_3_5
  STAGE_4
}

model NoveltySearchRun {
  id           String              @id @default(cuid())
  patentId     String?
  projectId    String? // Optional association with a project
  userId       String
  status       NoveltySearchStatus @default(PENDING)
  currentStage NoveltySearchStage  @default(STAGE_0)

  // Configuration
  config Json // NoveltySearchConfig

  // Input data
  inventionDescription String
  title                String
  jurisdiction         String @default("IN")
  filingType           String @default("utility")

  // Stage results
  stage0CompletedAt DateTime?
  stage0Results     Json? // NormalizedIdea

  stage1CompletedAt DateTime?
  stage1Results     Json? // ScreeningResult

  stage35CompletedAt DateTime?
  stage35Results     Json? // AssessmentResult[]

  stage4CompletedAt DateTime?
  stage4Results     Json? // Report data

  // Final output
  reportUrl String?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patent              Patent?                @relation(fields: [patentId], references: [id], onDelete: Cascade)
  project             Project?               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                User                   @relation(fields: [userId], references: [id])
  llmCalls            NoveltySearchLLMCall[]
  featureMapCells     FeatureMapCell[]
  aggregationSnapshot AggregationSnapshot?
  featureMapOverrides FeatureMapOverride[]

  @@map("novelty_search_runs")
}

model NoveltySearchLLMCall {
  id         String             @id @default(cuid())
  searchId   String
  stage      NoveltySearchStage
  taskCode   TaskCode
  prompt     String
  response   Json?
  tokensUsed Int?
  modelClass String?
  calledAt   DateTime           @default(now())

  // Relations
  search NoveltySearchRun @relation(fields: [searchId], references: [id], onDelete: Cascade)

  @@map("novelty_search_llm_calls")
}

model FeatureMapCell {
  id                String   @id @default(cuid())
  searchId          String
  publicationNumber String
  feature           String
  status            String // "Present", "Partial", "Absent", "Unknown"
  evidence          String?
  confidence        Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  search    NoveltySearchRun     @relation(fields: [searchId], references: [id], onDelete: Cascade)
  overrides FeatureMapOverride[]

  @@unique([searchId, publicationNumber, feature])
  @@map("feature_map_cells")
}

model AggregationSnapshot {
  id           String @id @default(cuid())
  searchId     String @unique
  noveltyScore Float
  decision     String // "Novel", "Partially Novel", "Not Novel", "Low Evidence"
  confidence   String // "High", "Medium", "Low"

  // Per-patent coverage data
  perPatentCoverage Json // Array of {pn, present_count, partial_count, absent_count, coverage_ratio}

  // Per-feature uniqueness data
  perFeatureUniqueness Json // Array of {feature, present_in, partial_in, absent_in, uniqueness}

  // Integration check
  integrationCheck Json // {any_single_patent_covers_majority, integration_pn, explanation}

  // Quality flags and risk factors
  qualityFlags Json // {low_evidence, ambiguous_abstracts, language_mismatch}
  riskFactors  Json // Array of risk factor strings

  // Metadata
  stats     Json // {patents_analyzed, avg_abstract_length_words}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  search NoveltySearchRun @relation(fields: [searchId], references: [id], onDelete: Cascade)

  @@map("aggregation_snapshots")
}

model FeatureMapOverride {
  id                String   @id @default(cuid())
  searchId          String
  publicationNumber String
  feature           String
  originalStatus    String // Original status before override
  overriddenStatus  String // New status after override
  evidence          String?
  reason            String // Reason for override
  overriddenBy      String // User ID who made the override
  overriddenAt      DateTime @default(now())

  // Relations
  search NoveltySearchRun @relation(fields: [searchId], references: [id], onDelete: Cascade)
  cell   FeatureMapCell   @relation(fields: [searchId, publicationNumber, feature], references: [searchId, publicationNumber, feature], onDelete: Cascade)

  @@unique([searchId, publicationNumber, feature])
  @@map("feature_map_overrides")
}

model FeatureMappingCache {
  id            String   @id @default(cuid())
  ideaHash      String
  batchHash     String
  promptVersion String   @default("v1.0")
  featureMaps   Json // Array of PatentFeatureMap results
  createdAt     DateTime @default(now())
  expiresAt     DateTime // When this cache entry expires

  @@unique([ideaHash, batchHash, promptVersion])
  @@map("feature_mapping_cache")
}

enum DraftingSessionStatus {
  IDEA_ENTRY
  RELATED_ART
  CLAIM_REFINEMENT
  COMPONENT_PLANNER
  FIGURE_PLANNER
  COUNTRY_WISE_DRAFTING
  DIAGRAM_GENERATOR
  ANNEXURE_DRAFT
  REVIEW_FIX
  EXPORT_READY
  COMPLETED
}

enum ComponentType {
  MAIN_CONTROLLER
  SUBSYSTEM
  MODULE
  INTERFACE
  SENSOR
  ACTUATOR
  PROCESSOR
  MEMORY
  DISPLAY
  COMMUNICATION
  POWER_SUPPLY
  OTHER
}

enum NumeralRange {
  HUNDREDS // 100-199: Main components
  TWO_HUNDREDS // 200-299: Sub-components
  THREE_HUNDREDS // 300-399: Modules
  FOUR_HUNDREDS // 400-499: Interfaces
  FIVE_HUNDREDS // 500-599: Sensors/Actuators
  SIX_HUNDREDS // 600-699: Processors
  SEVEN_HUNDREDS // 700-799: Memory
  EIGHT_HUNDREDS // 800-899: Displays
  NINE_HUNDREDS // 900-999: Other
}

model DraftingSession {
  id                    String                @id @default(cuid())
  patentId              String
  userId                String
  tenantId              String?
  status                DraftingSessionStatus @default(IDEA_ENTRY)
  draftingJurisdictions String[]              @default([])
  activeJurisdiction    String?

  // Multi-jurisdiction filing mode
  isMultiJurisdiction    Boolean @default(false) @map("is_multi_jurisdiction")
  referenceDraftComplete Boolean @default(false) @map("reference_draft_complete")
  referenceDraftId       String? @map("reference_draft_id") // ID of the AnnexureDraft with jurisdiction='REFERENCE'

  // Metadata
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  // Manual prior art data (Stage 3.5)
  manualPriorArt Json?
  priorArtConfig Json? @map("prior_art_config")

  // AI analysis data for related art (Stage 3.5)
  aiAnalysisData          Json?
  // Per-jurisdiction draft status (e.g., {"IN":{status:"done",latestVersion:2}})
  jurisdictionDraftStatus Json?

  // Paper writing fields (new)
  paperTypeId            String? // Reference to PaperTypeDefinition
  citationStyleId        String? // Reference to CitationStyleDefinition
  publicationVenueId     String? // Reference to PublicationVenue
  literatureReviewStatus LiteratureReviewStatus @default(NOT_STARTED)
  targetWordCount        Int? // Target total word count
  currentWordCount       Int? // Computed current word count

  // Relations
  patent        Patent         @relation(fields: [patentId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id])
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  ideaRecord    IdeaRecord?
  researchTopic ResearchTopic? // New: replaces IdeaRecord for paper writing
  referenceMap  ReferenceMap?

  // Paper writing relations
  paperType               PaperTypeDefinition?     @relation(fields: [paperTypeId], references: [id])
  citationStyle           CitationStyleDefinition? @relation(fields: [citationStyleId], references: [id])
  publicationVenue        PublicationVenue?        @relation(fields: [publicationVenueId], references: [id])
  citations               Citation[]
  figurePlans             FigurePlan[]
  diagramSources          DiagramSource[]
  annexureDrafts          AnnexureDraft[]
  history                 DraftingHistory[]
  // Stage 3.5 relations
  relatedArtRuns          RelatedArtRun[]
  relatedArtSelections    RelatedArtSelection[]
  // User section instructions
  userSectionInstructions UserSectionInstruction[]

  // User style overrides for this session
  userDiagramStyles       UserDiagramStyle[]
  userExportStyles        UserExportStyle[]
  userValidationOverrides UserValidationOverride[]

  // AI Review results
  aiReviews AIReviewResult[]

  // Sketch records
  sketchRecords SketchRecord[]

  // Literature search runs (persisted for AI analysis)
  literatureSearchRuns LiteratureSearchRun[]
  
  // Citation search strategy (systematic query generation)
  citationSearchStrategy CitationSearchStrategy?

  // Figure sequence for unified ordering of diagrams + sketches
  // Array of { type: 'diagram'|'sketch', sourceId: string, finalFigNo: number }
  figureSequence          Json?
  figureSequenceFinalized Boolean @default(false) @map("figure_sequence_finalized")

  // Paper Blueprint and Sections (new coherence system)
  paperBlueprint PaperBlueprint?
  paperSections  PaperSection[]

  @@map("drafting_sessions")
}

model IdeaRecord {
  id             String @id @default(cuid())
  sessionId      String @unique
  title          String
  rawInput       String // Original user input
  normalizedData Json // Structured JSON with all fields

  // Extracted fields for easy querying
  problem     String?
  objectives  String?
  components  Json? // Array of component descriptions
  logic       String?
  inputs      String?
  outputs     String?
  variants    String?
  bestMethod  String?
  // New: classification and abstract for linking with patent search APIs
  abstract    String?
  searchQuery String? // Compact search query for PQAI prior art search
  cpcCodes    String[]
  ipcCodes    String[]

  // LLM metadata
  llmPromptUsed String?
  llmResponse   Json?
  tokensUsed    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  session DraftingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("idea_records")
}

model ReferenceMap {
  id         String @id @default(cuid())
  sessionId  String @unique
  components Json // Array of {id, name, type, description, numeral, range}

  // Validation
  isValid          Boolean @default(false)
  validationErrors Json? // Array of validation issues

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  session DraftingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("reference_maps")
}

model FigurePlan {
  id          String  @id @default(cuid())
  sessionId   String
  figureNo    Int
  title       String
  nodes       Json // Array of component references included in figure
  edges       Json // Array of {from, to, label} connections
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  session DraftingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, figureNo])
  @@map("figure_plans")
}

model DiagramSource {
  id           String @id @default(cuid())
  sessionId    String
  figureNo     Int
  plantumlCode String
  checksum     String // For integrity verification

  // Language support for multi-jurisdiction translation
  language                String  @default("en") // ISO 639-1 code (en, ja, zh, de, fr, etc.)
  translatedFromDiagramId String? // Links to original (English) diagram for cross-referencing

  // Self-relation for translation linking
  translatedFrom DiagramSource?  @relation("DiagramTranslations", fields: [translatedFromDiagramId], references: [id], onDelete: SetNull)
  translations   DiagramSource[] @relation("DiagramTranslations")

  // Uploaded image metadata
  imageFilename   String?
  imagePath       String?
  imageChecksum   String?
  imageUploadedAt DateTime?

  // Original image backup (for image editor restore)
  originalImagePath     String?
  originalImageFilename String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  session DraftingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Unique per session + figure + language (allows multiple language versions)
  @@unique([sessionId, figureNo, language])
  @@index([sessionId, language]) // Fast lookup by session + language
  @@map("diagram_sources")
}

// === SKETCH GENERATION (Figure Planner - Sketch Tab) ===

enum SketchMode {
  AUTO // Generated from invention context only
  GUIDED // Invention context + user instructions
  REFINE // User-uploaded sketch + context refinement
}

enum SketchStatus {
  SUGGESTED // Suggested by LLM, not yet generated (placeholder)
  PENDING // Generation in progress
  SUCCESS // Successfully generated
  FAILED // Generation failed
}

model SketchRecord {
  id        String  @id @default(cuid())
  patentId  String
  sessionId String?
  figureNo  Int? // Optional linkage to a specific figure

  // Mode and status
  mode   SketchMode   @default(AUTO)
  status SketchStatus @default(PENDING)

  // Metadata
  title       String
  description String?

  // User prompt for GUIDED/REFINE/MODIFY
  userPrompt String?

  // Context configuration flags
  // e.g. { useIdeaSummary: true, useClaims: true, useDiagrams: true }
  contextFlags Json?

  // For modification chains - points to the sketch this was derived from
  sourceSketchId String?

  // Error handling
  errorMessage String?
  attemptCount Int     @default(0)

  // View configuration
  // e.g. { combinedView: true, separateViews: ['top','front'] }
  viewsRequested Json?

  // Generated image data
  imagePath     String?
  imageFilename String?
  imageWidth    Int?
  imageHeight   Int?
  imageChecksum String?

  // For REFINE mode - original uploaded sketch
  originalImagePath     String?
  originalImageFilename String?

  // AI generation metadata
  aiModel        String? // e.g., "gemini-3-pro-image-preview"
  aiPromptUsed   String? // Full prompt sent to AI (for debugging)
  aiResponseMeta Json? // Any additional metadata from AI response
  tokensUsed     Int?

  // User preferences
  isFavorite Boolean @default(false)
  isDeleted  Boolean @default(false) // Soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patent          Patent           @relation(fields: [patentId], references: [id], onDelete: Cascade)
  session         DraftingSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sourceSketch    SketchRecord?    @relation("SketchChain", fields: [sourceSketchId], references: [id], onDelete: SetNull)
  derivedSketches SketchRecord[]   @relation("SketchChain")

  @@index([patentId])
  @@index([sessionId])
  @@index([sourceSketchId])
  @@index([status])
  @@map("sketch_records")
}

model AnnexureDraft {
  id           String @id @default(cuid())
  sessionId    String
  version      Int    @default(1)
  jurisdiction String @default("IN")

  // === LEGACY COLUMNS (kept for backward compatibility) ===
  // These columns are still used for common sections across all jurisdictions
  title                      String
  fieldOfInvention           String?
  background                 String?
  summary                    String?
  briefDescriptionOfDrawings String?
  detailedDescription        String?
  bestMethod                 String?
  claims                     String?
  abstract                   String?
  industrialApplicability    String?
  listOfNumerals             String?

  // === SCALABLE SECTION STORAGE ===
  // JSON column for dynamic sections not covered by legacy columns
  // Stores: { "preamble": "...", "objectsOfInvention": "...", "technicalProblem": "...", etc. }
  // This allows new jurisdictions to add custom sections without schema changes
  extraSections Json? @default("{}")

  // Metadata
  fullDraftText    String // Complete assembled draft
  isValid          Boolean @default(false)
  validationReport Json? // Consistency check results

  // LLM metadata
  llmPromptUsed String?
  llmResponse   Json?
  tokensUsed    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  session   DraftingSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  aiReviews AIReviewResult[]

  @@map("annexure_drafts")
}

// === AI REVIEW RESULTS ===

model AIReviewResult {
  id           String  @id @default(cuid())
  sessionId    String  @map("session_id")
  draftId      String? @map("draft_id") // Links to specific AnnexureDraft
  jurisdiction String

  // Review Results
  issues  Json @default("[]") // Array of AIReviewIssue
  summary Json @default("{}") // { totalIssues, errors, warnings, suggestions, overallScore, recommendation }

  // Metadata
  reviewedAt DateTime @default(now()) @map("reviewed_at")
  tokensUsed Int?     @map("tokens_used")

  // Tracking for prompt improvements
  appliedFixes  Json @default("[]") // Array of { issueId, sectionKey, fixedAt, wasSuccessful }
  ignoredIssues Json @default("[]") // Array of issueIds that were ignored

  // Future: feedback for prompt tuning
  userFeedback Json? @default("{}") // { wasHelpful: boolean, comments: string, rating: number }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  session DraftingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  draft   AnnexureDraft?  @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@index([sessionId, jurisdiction])
  @@index([draftId])
  @@map("ai_review_results")
}

// === RELATED ART (Stage 3.5) MODELS ===

model RelatedArtRun {
  id          String   @id @default(cuid())
  sessionId   String
  queryText   String
  paramsJson  Json?
  resultsJson Json?
  ranBy       String
  ranAt       DateTime @default(now())

  // Relations
  session             DraftingSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  selections          RelatedArtSelection[]
  ideaBankSuggestions IdeaBankSuggestion[]

  @@index([sessionId])
  @@map("related_art_runs")
}

model RelatedArtSelection {
  id              String   @id @default(cuid())
  runId           String?
  sessionId       String
  patentNumber    String
  title           String?
  snippet         String?
  score           Decimal? @db.Decimal(5, 2)
  tags            String[]
  userNotes       String?
  publicationDate String?
  cpcCodes        String[] // Array of CPC codes
  ipcCodes        String[] // Array of IPC codes
  inventors       String[] // Array of inventor names
  assignees       String[] // Array of assignee names
  selectedAt      DateTime @default(now())

  // Relations
  run     RelatedArtRun?  @relation(fields: [runId], references: [id], onDelete: SetNull)
  session DraftingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, patentNumber, runId])
  @@index([runId])
  @@index([sessionId])
  @@map("related_art_selections")
}

// === IDEA BANK SUGGESTIONS ===
model IdeaBankSuggestion {
  id                  String   @id @default(cuid())
  relatedArtRunId     String
  modelVersion        String?
  ideaTitle           String
  corePrinciple       String
  expectedAdvantage   String
  tags                String[]
  nonObviousExtension String
  sourceBatchIndex    Int?     @default(0)
  confidenceScore     Float?
  createdAt           DateTime @default(now())

  // Relations
  run RelatedArtRun @relation(fields: [relatedArtRunId], references: [id], onDelete: Cascade)

  @@index([relatedArtRunId])
  @@map("idea_bank_suggestions")
}

// === NOVELTY IDEA BANK SUGGESTIONS (independent of drafting) ===

model DraftingHistory {
  id        String                @id @default(cuid())
  sessionId String
  action    String // IDEA_UPDATED, COMPONENTS_ASSIGNED, FIGURE_PLAN_CHANGED, etc.
  userId    String
  stage     DraftingSessionStatus

  // Data changes
  previousData Json?
  newData      Json?
  notes        String?

  timestamp DateTime @default(now())

  // Relations
  session DraftingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id])

  @@map("drafting_history")
}

model UserCredit {
  userId       String    @id // References User.id
  totalCredits Int       @default(100) // Monthly allowance
  usedCredits  Int       @default(0)
  monthlyReset DateTime // When credits reset
  lastSearchAt DateTime?
  planTier     String    @default("free") // free, basic, pro, enterprise

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_credits")
}

// === IDEA BANK MODELS ===

enum IdeaBankStatus {
  PUBLIC // Available for everyone to see and reserve
  RESERVED // Reserved by a user, content redacted
  LICENSED // Licensed/commercialized
  ARCHIVED // No longer available
}

enum IdeaBankReservationStatus {
  ACTIVE
  EXPIRED
  RELEASED
}

model IdeaBankIdea {
  id             String         @id @default(cuid())
  title          String
  description    String
  abstract       String? // Patent abstract format
  domainTags     String[] // Array of domain tags
  technicalField String? // Primary technical field
  noveltyScore   Float? // AI-calculated novelty score (0-1)
  status         IdeaBankStatus @default(PUBLIC)

  // Source information
  generatedBy       String? // AI model/version that generated this
  sourceBatchId     String? // Batch ID for tracking generations
  derivedFromIdeaId String? // If this is a derived/edited idea

  // Content metadata
  keyFeatures           String[] // Array of key technical features
  potentialApplications String[] // Array of potential applications
  priorArtSummary       String? // Summary of prior art analysis

  // Ownership and access
  createdBy String // User ID who created/uploaded this idea
  tenantId  String? // Tenant this idea belongs to (null for global)

  // Reservation tracking
  reservedCount Int @default(0) // How many times this idea has been reserved

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime? // When made available in idea bank

  // Relations
  creator      User                  @relation("IdeaBankIdeaCreator", fields: [createdBy], references: [id])
  tenant       Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  derivedFrom  IdeaBankIdea?         @relation("IdeaBankDerivation", fields: [derivedFromIdeaId], references: [id])
  derivedIdeas IdeaBankIdea[]        @relation("IdeaBankDerivation")
  reservations IdeaBankReservation[]
  history      IdeaBankHistory[]

  @@index([status])
  @@index([domainTags])
  @@index([technicalField])
  @@index([createdBy])
  @@index([tenantId])
  @@map("idea_bank_ideas")
}

model IdeaBankReservation {
  id     String                    @id @default(cuid())
  ideaId String
  userId String
  status IdeaBankReservationStatus @default(ACTIVE)

  // Reservation details
  reservedAt DateTime  @default(now())
  expiresAt  DateTime // When reservation expires (default 30 days)
  releasedAt DateTime? // When user released the reservation

  // Usage tracking
  sentToNoveltySearch Boolean @default(false)
  sentToDrafting      Boolean @default(false)

  // Relations
  idea IdeaBankIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId]) // One reservation per user per idea
  @@index([userId, status])
  @@index([expiresAt])
  @@map("idea_bank_reservations")
}

model IdeaBankHistory {
  id     String @id @default(cuid())
  ideaId String
  action String // CREATED, EDITED, RESERVED, RELEASED, SENT_TO_SEARCH, SENT_TO_DRAFTING, etc.
  userId String

  // Change tracking
  previousData Json? // Previous state
  newData      Json? // New state after change
  notes        String? // Optional notes about the change

  timestamp DateTime @default(now())

  // Relations
  idea IdeaBankIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])

  @@index([ideaId, timestamp])
  @@index([userId])
  @@map("idea_bank_history")
}

// === PERSONA SYNC (STYLE LEARNING) MODELS ===

enum StyleProfileStatus {
  NOT_LEARNED
  LEARNING
  LEARNED
  NEEDS_MORE_DATA
  FAILED
}

enum StyleTrainingJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DocumentType {
  SAMPLE // Training samples for style learning
  REFERENCE // Reference documents
}

model StyleProfile {
  id        String             @id @default(cuid())
  tenantId  String
  userId    String
  version   Int                @default(1)
  json      Json // StyleProfile JSON schema
  status    StyleProfileStatus @default(NOT_LEARNED)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  createdBy String
  lockedAt  DateTime?
  lockedBy  String?

  // Relations
  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User   @relation("StyleProfileUser", fields: [userId], references: [id])
  creator User   @relation("StyleProfileCreator", fields: [createdBy], references: [id])
  locker  User?  @relation("StyleProfileLocker", fields: [lockedBy], references: [id])

  // Indexes
  @@unique([tenantId, userId, version])
  @@index([tenantId, userId])
  @@index([status])
  @@map("style_profiles")
}

model StyleTrainingJob {
  id             String                 @id @default(cuid())
  tenantId       String
  userId         String
  status         StyleTrainingJobStatus @default(PENDING)
  inputsMetadata Json? // Array of {docId, filename, tokens, hash}
  metrics        Json? // Learning metrics: {totalTokens, entropy, coverage, ngrams}
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  // Indexes
  @@index([tenantId, userId])
  @@index([status])
  @@map("style_training_jobs")
}

model Document {
  id         String       @id @default(cuid())
  tenantId   String
  userId     String
  type       DocumentType @default(SAMPLE)
  filename   String
  contentPtr String? // File path or storage reference
  tokens     Int          @default(0) // Token count
  hash       String // Content hash for integrity
  mimeType   String?
  sizeBytes  Int?
  createdAt  DateTime     @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  // Indexes
  @@index([tenantId, userId, type])
  @@index([hash])
  @@map("documents")
}

// === WRITING SAMPLES FOR EXAMPLE-BASED STYLE MIMICRY ===

// Persona visibility levels
enum PersonaVisibility {
  PRIVATE // Only creator can see/use
  ORGANIZATION // Everyone in tenant can see/use
}

// Writing Persona - Reusable style profiles that can be shared
model WritingPersona {
  id        String @id @default(cuid())
  tenantId  String
  createdBy String // User who created this persona

  name        String // "CSE Patents", "Pharma Style", "Firm Standard"
  description String? // "Formal claims, detailed embodiments"

  visibility PersonaVisibility @default(PRIVATE)
  isTemplate Boolean           @default(false) // Firm-wide templates marked by admin
  allowCopy  Boolean           @default(true) // Others can copy to their own

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User            @relation("PersonaCreator", fields: [createdBy], references: [id])
  samples WritingSample[]

  // A user can have multiple personas, but names must be unique per user
  @@unique([createdBy, name])
  @@index([tenantId, visibility]) // For finding org-wide personas
  @@index([createdBy])
  @@map("writing_personas")
}

model WritingSample {
  id          String  @id @default(cuid())
  userId      String
  tenantId    String
  personaId   String? // Reference to WritingPersona (optional for backward compat)
  personaName String  @default("Default") // Kept for backward compatibility

  jurisdiction String // "IN", "US", "EP", "*" (universal/all jurisdictions)
  sectionKey   String // "claims", "detailedDescription", "abstract", "background", etc.

  sampleText String  @db.Text // User's writing sample (3-4 lines, ~100-150 words)
  notes      String? // Optional notes: "My preferred claims opening style"

  isShared  Boolean @default(false) // Deprecated: use persona.visibility instead
  isActive  Boolean @default(true)
  wordCount Int     @default(0) // Computed word count for validation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  persona WritingPersona? @relation(fields: [personaId], references: [id], onDelete: SetNull)

  // Constraints - samples unique per user per jurisdiction per persona per section
  @@unique([userId, jurisdiction, personaId, sectionKey])
  @@index([tenantId, userId])
  @@index([userId, jurisdiction])
  @@index([personaId])
  @@map("writing_samples")
}

// === COUNTRY PROFILES FOR JURISDICTION-AWARE DRAFTING ===

enum CountryProfileStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

model CountryProfile {
  id          String               @id @default(cuid())
  countryCode String               @unique // e.g., "US", "IN", "EP"
  name        String // e.g., "United States", "India", "European Patent Office"
  profileData Json // Complete country_profile.json structure
  version     Int                  @default(1)
  status      CountryProfileStatus @default(DRAFT)
  createdBy   String
  updatedBy   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  // Relations
  creator User  @relation("CountryProfileCreator", fields: [createdBy], references: [id])
  updater User? @relation("CountryProfileUpdater", fields: [updatedBy], references: [id])

  // Indexes
  @@index([countryCode])
  @@index([status])
  @@map("country_profiles")
}

// Superset sections - the universal foundation for all patent drafting
// These are the canonical sections that all countries map to
model SupersetSection {
  id           String   @id @default(cuid())
  sectionKey   String   @unique @map("section_key") // e.g., "title", "background", "claims"
  aliases      String[] @default([]) @map("aliases") // Alternative keys that map to this section
  displayOrder Int      @map("display_order") // Order in the drafting flow
  label        String // Display label: "Title of the Invention"
  description  String?  @db.Text // Description of what this section contains
  instruction  String   @db.Text // Base prompt instruction for LLM
  constraints  Json     @default("[]") // Base constraints array
  isRequired   Boolean  @default(true) @map("is_required") // Default required status
  isActive     Boolean  @default(true) @map("is_active") // Can be disabled without deleting

  // Context injection flags - determines what data to inject into section prompts
  requiresPriorArt   Boolean @default(false) @map("requires_prior_art") // Inject prior art references (background, crossReference, etc.)
  requiresFigures    Boolean @default(false) @map("requires_figures") // Inject figure list (briefDescriptionOfDrawings, detailedDescription)
  requiresClaims     Boolean @default(false) @map("requires_claims") // Inject claims context (abstract, summary)
  requiresComponents Boolean @default(false) @map("requires_components") // Inject component/numeral list (detailedDescription)

  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Note: Mappings relation defined at application level for flexibility
  // mappings CountrySectionMapping[]

  @@index([displayOrder])
  @@index([isActive])
  @@map("superset_sections")
}

// Mapping of canonical superset sections to country-specific headings/labels
model CountrySectionMapping {
  id           String  @id @default(cuid())
  countryCode  String  @map("country_code")
  supersetCode String  @map("superset_code") // e.g., "01. Title", "05. Background"
  sectionKey   String  @map("section_key") // canonical superset key, e.g., "title", "background"
  heading      String // Country-specific heading text (may be N/A)
  isRequired   Boolean @default(true) @map("is_required") // Whether this section is required for this country
  isEnabled    Boolean @default(true) @map("is_enabled") // Whether to include in drafting for this country
  displayOrder Int?    @map("display_order") // Country-specific order override

  // Country-specific overrides for context injection (null = use SupersetSection default)
  requiresPriorArtOverride   Boolean? @map("requires_prior_art_override") // Override: inject prior art
  requiresFiguresOverride    Boolean? @map("requires_figures_override") // Override: inject figures
  requiresClaimsOverride     Boolean? @map("requires_claims_override") // Override: inject claims
  requiresComponentsOverride Boolean? @map("requires_components_override") // Override: inject components

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relation to superset section (optional - can be enforced later after seeding)
  // Note: Foreign key relationship is intentionally soft to allow incremental data migration
  // supersetSection SupersetSection? @relation(fields: [sectionKey], references: [sectionKey], onDelete: Restrict)

  @@unique([countryCode, supersetCode])
  @@unique([countryCode, sectionKey])
  @@index([countryCode])
  @@index([sectionKey])
  @@map("country_section_mappings")
}

// Mapping of country codes to display names
model CountryName {
  code      String   @id @map("code")
  name      String
  continent String   @default("Unknown")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("country_names")
}

// Country-specific top-up prompts for sections (database-driven)
model CountrySectionPrompt {
  id                    String                     @id @default(cuid())
  countryCode           String                     @map("country_code")
  sectionKey            String                     @map("section_key") // canonical key: "title", "background", "objectsOfInvention", etc.
  instruction           String                     @db.Text // Top-up instruction to merge with base superset prompt
  constraints           Json                       @default("[]") // Array of constraint strings
  additions             Json?                      @default("[]") // Array of additional guidance strings
  importFiguresDirectly Boolean                    @default(false) @map("import_figures_directly") // When true, bypass LLM and directly import figure titles
  version               Int                        @default(1)
  status                CountrySectionPromptStatus @default(ACTIVE)
  createdBy             String?                    @map("created_by")
  updatedBy             String?                    @map("updated_by")
  createdAt             DateTime                   @default(now()) @map("created_at")
  updatedAt             DateTime                   @updatedAt @map("updated_at")

  // Version history relation
  history CountrySectionPromptHistory[]

  @@unique([countryCode, sectionKey], name: "country_section_unique")
  @@index([countryCode])
  @@index([sectionKey])
  @@index([status])
  @@map("country_section_prompts")
}

enum CountrySectionPromptStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

// Audit trail for prompt changes
model CountrySectionPromptHistory {
  id           String   @id @default(cuid())
  promptId     String   @map("prompt_id")
  countryCode  String   @map("country_code")
  sectionKey   String   @map("section_key")
  instruction  String   @db.Text
  constraints  Json     @default("[]")
  additions    Json?    @default("[]")
  version      Int
  changeType   String   @map("change_type") // CREATE, UPDATE, ARCHIVE, RESTORE
  changeReason String?  @map("change_reason")
  changedBy    String?  @map("changed_by")
  changedAt    DateTime @default(now()) @map("changed_at")

  // Relation to parent prompt
  prompt CountrySectionPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@index([countryCode, sectionKey])
  @@map("country_section_prompt_history")
}

// User-specific section instructions - can be session-level OR user-level (persistent)
// - sessionId = null + userId = user-level (persists across all drafts for that paper type)
// - sessionId = X + userId = session-level (applies only to that specific draft)
// Supports paper-type-specific instructions (different for JOURNAL vs CONFERENCE)
model UserSectionInstruction {
  id            String   @id @default(cuid())
  sessionId     String?  @map("session_id") // NULL = user-level persistent instruction
  userId        String   @map("user_id") // Required - owner of the instruction
  jurisdiction  String   @default("*") // "*" = all (legacy for patents)
  paperTypeCode String?  @map("paper_type_code") // For papers: JOURNAL_ARTICLE, CONFERENCE_PAPER, etc.
  sectionKey    String   @map("section_key")
  instruction   String   @db.Text // User's custom instruction for this section
  emphasis      String?  @db.Text // What to emphasize/focus on
  avoid         String?  @db.Text // What to avoid/exclude
  style         String? // "formal", "technical", "concise", etc.
  wordCount     Int?     @map("word_count") // Target word count override
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relation to drafting session (optional for user-level instructions)
  session DraftingSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // Relation to user
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Unique per user + optional session + jurisdiction/paperType + section
  // This allows both user-level (sessionId=null) and session-level instructions
  @@unique([userId, sessionId, jurisdiction, sectionKey])
  @@index([sessionId])
  @@index([userId])
  @@index([userId, jurisdiction])
  @@index([userId, sessionId, jurisdiction])
  @@index([userId, paperTypeCode, sectionKey])
  @@index([sectionKey])
  @@map("user_section_instructions")
}

// ============================================================================
// PAPER WRITING PERSONAS (Example-based style mimicry for papers)
// ============================================================================

// Paper Writing Persona - Reusable style profiles for academic writing
model PaperWritingPersona {
  id        String @id @default(cuid())
  tenantId  String @map("tenant_id")
  createdBy String @map("created_by") // User who created this persona

  name        String // "Journal Style", "Conference Style", "Formal Academic"
  description String? @db.Text // "Concise, active voice, data-driven"

  visibility PersonaVisibility @default(PRIVATE)
  isTemplate Boolean           @default(false) // Org-wide templates marked by admin
  allowCopy  Boolean           @default(true) // Others can copy to their own

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User                @relation("PaperPersonaCreator", fields: [createdBy], references: [id])
  samples PaperWritingSample[]

  // A user can have multiple personas, but names must be unique per user
  @@unique([createdBy, name])
  @@index([tenantId, visibility])
  @@index([createdBy])
  @@map("paper_writing_personas")
}

// Paper Writing Sample - Example text for style mimicry
model PaperWritingSample {
  id          String  @id @default(cuid())
  userId      String  @map("user_id")
  tenantId    String  @map("tenant_id")
  personaId   String? @map("persona_id") // Reference to PaperWritingPersona
  personaName String  @default("Default") @map("persona_name") // For backward compat

  paperTypeCode String @map("paper_type_code") // "JOURNAL_ARTICLE", "CONFERENCE_PAPER", "*" (universal)
  sectionKey    String @map("section_key") // "abstract", "introduction", "methodology", etc.

  sampleText String  @map("sample_text") @db.Text // User's writing sample (100-300 words)
  notes      String? @db.Text // Optional notes: "My preferred intro style for journals"

  isShared  Boolean @default(false) @map("is_shared") // Deprecated: use persona.visibility
  isActive  Boolean @default(true) @map("is_active")
  wordCount Int     @default(0) @map("word_count") // Computed word count for validation

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  persona PaperWritingPersona? @relation(fields: [personaId], references: [id], onDelete: SetNull)

  // Unique per user per paper type per persona per section
  @@unique([userId, paperTypeCode, personaId, sectionKey])
  @@index([tenantId, userId])
  @@index([userId, paperTypeCode])
  @@index([personaId])
  @@map("paper_writing_samples")
}

// ============================================================================
// JURISDICTION STYLE CONFIGURATION (Diagrams, Export, Validation)
// ============================================================================

// === SECTION VALIDATION RULES (Per jurisdiction, per section) ===
// Stores word/char limits and validation rules for AI reviewer
model CountrySectionValidation {
  id          String @id @default(cuid())
  countryCode String @map("country_code")
  sectionKey  String @map("section_key") // "title", "abstract", "claims", etc.

  // Word limits
  maxWords         Int? @map("max_words") // e.g., 150 for abstract
  minWords         Int? @map("min_words") // e.g., 50 for detailed_description
  recommendedWords Int? @map("recommended_words") // Soft recommendation

  // Character limits
  maxChars         Int? @map("max_chars") // e.g., 500 for title
  minChars         Int? @map("min_chars")
  recommendedChars Int? @map("recommended_chars")

  // Count limits (for claims)
  maxCount            Int? @map("max_count") // e.g., 20 total claims
  maxIndependent      Int? @map("max_independent") // e.g., 3 independent claims
  countBeforeExtraFee Int? @map("count_before_extra_fee") // Fee threshold

  // Severity and messaging
  wordLimitSeverity  String? @map("word_limit_severity") // "error", "warning", "info"
  charLimitSeverity  String? @map("char_limit_severity")
  countLimitSeverity String? @map("count_limit_severity")
  wordLimitMessage   String? @map("word_limit_message") @db.Text
  charLimitMessage   String? @map("char_limit_message") @db.Text
  countLimitMessage  String? @map("count_limit_message") @db.Text

  // Legal citation for message (helps AI reviewer)
  legalReference String? @map("legal_reference") // e.g., "Rule 13(7)(b)", "37 CFR 1.72(a)"

  // Additional validation rules as JSON (future extensibility)
  // Examples: { "mustStartWith": "The principal object", "forbiddenPhrases": ["patent", "novel"] }
  additionalRules Json? @default("{}") @map("additional_rules")

  version   Int                        @default(1)
  status    CountrySectionPromptStatus @default(ACTIVE)
  createdBy String?                    @map("created_by")
  updatedBy String?                    @map("updated_by")
  createdAt DateTime                   @default(now()) @map("created_at")
  updatedAt DateTime                   @updatedAt @map("updated_at")

  @@unique([countryCode, sectionKey])
  @@index([countryCode])
  @@index([sectionKey])
  @@map("country_section_validations")
}

// === CROSS-SECTION VALIDATION CHECKS (For AI Reviewer) ===
// Stores validation rules that span multiple sections
model CountryCrossValidation {
  id          String @id @default(cuid())
  countryCode String @map("country_code")
  checkId     String @map("check_id") // Unique check identifier like "claims_supported_by_description"

  // Check configuration
  checkType   String   @map("check_type") // "support", "consistency", "reference", "coverage"
  fromSection String   @map("from_section") // Source section: "claims"
  toSections  String[] @map("to_sections") // Target sections: ["detailed_description"]

  // Severity and messaging
  severity String @default("warning") // "error", "warning", "info"
  message  String @db.Text // Human-readable message for UI

  // AI Reviewer prompt context
  reviewPrompt String? @map("review_prompt") @db.Text // Specific instruction for AI reviewer
  legalBasis   String? @map("legal_basis") @db.Text // Legal citation: "Section 10(4) of Patents Act"

  // Additional check parameters as JSON
  // Examples: { "checkReferenceNumerals": true, "checkAntecedentBasis": true }
  checkParams Json? @default("{}") @map("check_params")

  isEnabled Boolean  @default(true) @map("is_enabled")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([countryCode, checkId])
  @@index([countryCode])
  @@index([checkType])
  @@map("country_cross_validations")
}

// === DIAGRAM CONFIGURATION (Per jurisdiction) ===
model CountryDiagramConfig {
  id          String @id @default(cuid())
  countryCode String @unique @map("country_code")

  // Core diagram settings
  requiredWhenApplicable     Boolean  @default(true) @map("required_when_applicable")
  supportedDiagramTypes      String[] @default([]) @map("supported_types") // ["block", "flowchart", "schematic"]
  figureLabelFormat          String   @default("Fig. {number}") @map("figure_label_format")
  autoGenerateReferenceTable Boolean  @default(true) @map("auto_reference_table")

  // Drawing rules (from rules.drawings)
  paperSize                  String  @default("A4") @map("paper_size")
  colorAllowed               Boolean @default(false) @map("color_allowed")
  colorUsageNote             String? @map("color_usage_note") @db.Text
  lineStyle                  String  @default("black_and_white_solid") @map("line_style")
  referenceNumeralsMandatory Boolean @default(true) @map("ref_numerals_mandatory")
  minReferenceTextSizePt     Int     @default(8) @map("min_ref_text_size_pt")

  // Drawing margins (cm)
  drawingMarginTopCm    Float @default(2.5) @map("drawing_margin_top_cm")
  drawingMarginBottomCm Float @default(1.0) @map("drawing_margin_bottom_cm")
  drawingMarginLeftCm   Float @default(2.5) @map("drawing_margin_left_cm")
  drawingMarginRightCm  Float @default(1.5) @map("drawing_margin_right_cm")

  // LLM generation defaults
  defaultDiagramCount    Int @default(4) @map("default_diagram_count")
  maxDiagramsRecommended Int @default(10) @map("max_diagrams_recommended")

  version   Int                        @default(1)
  status    CountrySectionPromptStatus @default(ACTIVE)
  createdBy String?                    @map("created_by")
  updatedBy String?                    @map("updated_by")
  createdAt DateTime                   @default(now()) @map("created_at")
  updatedAt DateTime                   @updatedAt @map("updated_at")

  // Relations
  diagramHints CountryDiagramHint[]

  @@index([countryCode])
  @@map("country_diagram_configs")
}

// === PER-DIAGRAM-TYPE GENERATION HINTS ===
model CountryDiagramHint {
  id          String @id @default(cuid())
  configId    String @map("config_id")
  diagramType String @map("diagram_type") // "block", "flowchart", "schematic", "perspective_view"

  // LLM instruction for this diagram type
  hint String @db.Text // "Use rectangles for components and arrows for data flow..."

  // Optional: specific PlantUML/Mermaid preferences
  preferredSyntax String? @map("preferred_syntax") // "plantuml", "mermaid"
  exampleCode     String? @map("example_code") @db.Text // Example PlantUML/Mermaid snippet

  // Constraints for this diagram type
  maxElements   Int?    @map("max_elements") // Max components in diagram
  requireLabels Boolean @default(true) @map("require_labels")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relation
  config CountryDiagramConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, diagramType])
  @@index([configId])
  @@map("country_diagram_hints")
}

// === EXPORT CONFIGURATION (Per jurisdiction, per document type) ===
model CountryExportConfig {
  id             String @id @default(cuid())
  countryCode    String @map("country_code")
  documentTypeId String @map("document_type_id") // "spec_pdf", "claims_only", "abstract_only"

  // Display info
  label       String // "Indian Complete Specification PDF (Form 2)"
  description String? @db.Text

  // Page layout
  pageSize       String @default("A4") @map("page_size") // "A4", "LETTER"
  marginTopCm    Float  @default(2.5) @map("margin_top_cm")
  marginBottomCm Float  @default(2.0) @map("margin_bottom_cm")
  marginLeftCm   Float  @default(2.5) @map("margin_left_cm")
  marginRightCm  Float  @default(2.0) @map("margin_right_cm")

  // Typography
  fontFamily        String  @default("Times New Roman") @map("font_family")
  fontSizePt        Int     @default(12) @map("font_size_pt")
  lineSpacing       Float   @default(1.5) @map("line_spacing")
  headingFontFamily String? @map("heading_font_family")
  headingFontSizePt Int?    @map("heading_font_size_pt")

  // Document options
  addPageNumbers      Boolean @default(true) @map("add_page_numbers")
  addParagraphNumbers Boolean @default(false) @map("add_paragraph_numbers")
  pageNumberFormat    String  @default("Page {page} of {total}") @map("page_number_format")
  pageNumberPosition  String  @default("header-right") @map("page_number_position") // "header-right", "footer-center"

  // Section configuration
  includesSections String[] @default([]) @map("includes_sections") // ["title", "field", "background", ...]
  sectionOrder     String[] @default([]) @map("section_order") // Override default order if needed

  // Additional export options as JSON
  // Examples: { "includeTableOfContents": true, "watermark": "DRAFT" }
  exportOptions Json? @default("{}") @map("export_options")

  version   Int                        @default(1)
  status    CountrySectionPromptStatus @default(ACTIVE)
  createdBy String?                    @map("created_by")
  updatedBy String?                    @map("updated_by")
  createdAt DateTime                   @default(now()) @map("created_at")
  updatedAt DateTime                   @updatedAt @map("updated_at")

  // Relations
  sectionHeadings CountryExportHeading[]

  @@unique([countryCode, documentTypeId])
  @@index([countryCode])
  @@map("country_export_configs")
}

// === SECTION HEADINGS FOR EXPORT (Per jurisdiction, per document type) ===
model CountryExportHeading {
  id             String @id @default(cuid())
  exportConfigId String @map("export_config_id")
  sectionKey     String @map("section_key") // "field", "background", "claims"

  heading String // "FIELD OF INVENTION", "BACKGROUND AND PRIOR ART"
  style   String @default("uppercase") // "uppercase", "titlecase", "sentence"

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relation
  exportConfig CountryExportConfig @relation(fields: [exportConfigId], references: [id], onDelete: Cascade)

  @@unique([exportConfigId, sectionKey])
  @@index([exportConfigId])
  @@map("country_export_headings")
}

