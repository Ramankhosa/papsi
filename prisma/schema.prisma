// ============================================================================
// IMPORT/SYNC TRACKING (For JSON imports by super admin)
// ============================================================================

// Track JSON imports for audit and rollback
model CountryConfigImport {
  id          String @id @default(cuid())
  countryCode String @map("country_code")
  importType  String @map("import_type") // "full", "validation_only", "diagram_only", "export_only"

  // Source JSON (stored for rollback)
  sourceJson Json   @map("source_json")
  sourceHash String @map("source_hash") // SHA256 of JSON for deduplication

  // Import results
  status         String @default("pending") // "pending", "processing", "completed", "failed", "rolled_back"
  recordsCreated Int    @default(0) @map("records_created")
  recordsUpdated Int    @default(0) @map("records_updated")
  recordsSkipped Int    @default(0) @map("records_skipped")
  errorLog       Json?  @map("error_log") // Array of error objects

  // Rollback support
  previousState Json?     @map("previous_state") // Snapshot before import for rollback
  rolledBackAt  DateTime? @map("rolled_back_at")
  rolledBackBy  String?   @map("rolled_back_by")

  importedBy  String    @map("imported_by")
  importedAt  DateTime  @default(now()) @map("imported_at")
  completedAt DateTime? @map("completed_at")

  // Relation
  importer User @relation("ConfigImporter", fields: [importedBy], references: [id])

  @@index([countryCode])
  @@index([status])
  @@index([importedBy])
  @@map("country_config_imports")
}

// ============================================================================
// IDEATION ENGINE (Mind-Map Patent Ideation)
// ============================================================================

enum IdeationSessionStatus {
  SEED_INPUT // Initial seed entry
  CLARIFYING // Asking clarifying questions
  CLASSIFYING // Running classification
  EXPANDING // Dimension expansion in progress
  EXPLORING // User exploring mind-map
  GENERATING // Generating idea frames
  NOVELTY_CHECK // Running novelty searches
  REVIEWING // User reviewing generated ideas
  COMPLETED // Session finalized
  ARCHIVED // Session archived
}

enum InventionClass {
  PRODUCT_DEVICE // Physical object: syringe, umbrella, shoe
  SYSTEM // Multiple interacting components
  METHOD_PROCESS // Steps: manufacturing, operating, analysis
  COMPOSITION // Chemical, materials, mixtures
  SOFTWARE_ALGORITHM // Pure logic/data
  BIOTECH_PHARMA // Bio materials, treatment
  MANUFACTURING // Process + tooling + QA
  SERVICE_WORKFLOW // Human-centered operational method
  HYBRID // Multiple strong labels
}

enum Archetype {
  MECH // Mechanical
  ELEC // Electrical/Electronic
  SOFT // Software
  CHEM // Chemical
  BIO // Biological
  MIXED // Mixed archetype
}

enum ForkMode {
  SINGLE // Single track
  FORK // Multiple parallel tracks
  MERGE // Merged from fork
}

enum MindMapNodeType {
  SEED // Root seed node
  COMPONENT // Physical/logical component
  DIMENSION_FAMILY // Dimension category (Material, Mechanism, Risk, etc.)
  DIMENSION_OPTION // Specific dimension value
  OPERATOR // TRIZ-like operator
  CONSTRAINT // User constraint
  IDEA_FRAME // Generated idea
  EVIDENCE_CLUSTER // Grouped evidence
}

enum MindMapNodeState {
  EXPANDED // Fully expanded
  COLLAPSED // Collapsed (children hidden)
  HIDDEN // Hidden by user
  REMOVED // Soft-deleted
  SELECTED // In combine tray
}

enum IdeaFrameStatus {
  DRAFT // Just generated
  SHORTLISTED // User shortlisted
  REJECTED // User rejected
  EXPORTED // Sent to Idea Bank
  ARCHIVED // Archived
}

enum SaturationLevel {
  LOW
  MEDIUM
  HIGH
}

enum NoveltyAction {
  KEEP // Keep as is
  MUTATE_OPERATOR // Try different operator
  MUTATE_DIMENSION // Try different dimension
  NARROW_MICRO_PROBLEM // Focus on sub-problem
  ASK_USER_QUESTION // Need user input
}

// Main ideation session
model IdeationSession {
  id       String @id @default(cuid())
  tenantId String
  userId   String

  // Session state
  status IdeationSessionStatus @default(SEED_INPUT)

  // Seed data
  seedText        String   @db.Text
  seedGoal        String?  @db.Text // Optional goal statement
  seedConstraints String[] @default([])

  // Normalization result (InputNormalization JSON)
  normalizationJson Json?

  // Classification result (Classification JSON)
  classificationJson Json?

  // Settings
  settingsJson Json? // {deterministicSeed, modelChoices, budgetCaps}
  budgetCap    String @default("MEDIUM") // LOW, MEDIUM, HIGH

  // Track which tracks are active (for fork mode)
  activeTracks String[] @default([])

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  // Relations
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodes           MindMapNode[]
  edges           MindMapEdge[]
  combineTray     CombineTray?
  ideaFrames      IdeaFrame[]
  evidenceResults EvidenceResult[]
  history         IdeationHistory[]

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@map("ideation_sessions")
}

// Mind-map nodes
model MindMapNode {
  id        String @id @default(cuid())
  sessionId String

  // Node identification
  nodeId String // Graph-local ID (e.g., "seed-1", "dim-material-1")
  type   MindMapNodeType

  // Node content
  title       String
  description String? @db.Text

  // Categorization
  family String? // Dimension family (Material, Mechanism, Lifecycle, Risk, etc.)
  tags   String[] @default([])

  // State
  state           MindMapNodeState @default(COLLAPSED)
  selectable      Boolean          @default(true)
  defaultExpanded Boolean          @default(false)

  // Hierarchy
  parentNodeId String? // Parent node ID (graph-local)
  depth        Int     @default(0)

  // Metadata
  payloadJson Json? // Type-specific data
  createdBy   String @default("system") // "system" or "user"

  // Position (for React Flow)
  positionX Float?
  positionY Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  session IdeationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, nodeId])
  @@index([sessionId])
  @@index([sessionId, type])
  @@index([sessionId, state])
  @@map("mindmap_nodes")
}

// Mind-map edges (connections between nodes)
model MindMapEdge {
  id        String @id @default(cuid())
  sessionId String

  // Edge definition
  fromNodeId String // Source node (graph-local ID)
  toNodeId   String // Target node (graph-local ID)
  relation   String // Relationship type: "contains", "enables", "requires", "produces", etc.

  // Optional label
  label String?

  // Styling
  animated Boolean @default(false)

  createdAt DateTime @default(now())

  // Relations
  session IdeationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, fromNodeId, toNodeId])
  @@index([sessionId])
  @@map("mindmap_edges")
}

// Combine tray - user's current selection for idea generation
model CombineTray {
  id        String @id @default(cuid())
  sessionId String @unique

  // Selected items (arrays of graph-local node IDs)
  selectedComponents String[] @default([])
  selectedDimensions String[] @default([])
  selectedOperators  String[] @default([])

  // Recipe configuration
  recipeIntent   String @default("divergent") // divergent, convergent, risk-reduction, cost-reduction
  requestedCount Int    @default(5) // How many ideas to generate

  // Full recipe JSON (CombineRecipe schema)
  recipeJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  session IdeationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("combine_trays")
}

// Generated idea frames
model IdeaFrame {
  id        String @id @default(cuid())
  sessionId String

  // Core content (IdeaFrame JSON schema)
  ideaFrameJson Json // Full structured idea

  // Quick-access fields
  title           String
  problem         String  @db.Text
  principle       String  @db.Text // One-liner
  technicalEffect String? @db.Text

  // Classification
  classLabels String[] @default([])

  // Traceability
  operatorsUsed  String[] @default([])
  dimensionsUsed String[] @default([])
  componentsUsed String[] @default([])

  // Status tracking
  status IdeaFrameStatus @default(DRAFT)

  // Novelty assessment
  noveltyScore       Int? // 0-100
  noveltySummaryJson Json? // NoveltyGate JSON
  conceptSaturation  SaturationLevel?
  solutionSaturation SaturationLevel?

  // User interaction
  userNotes  String? @db.Text
  userRating Int? // 1-5 stars

  // Export tracking
  exportedToIdeaId String? // ID of IdeaBankIdea if exported
  exportedAt       DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  session         IdeationSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  evidenceResults EvidenceResult[]

  @@index([sessionId])
  @@index([sessionId, status])
  @@map("idea_frames")
}

// Evidence from novelty searches
model EvidenceResult {
  id          String  @id @default(cuid())
  sessionId   String
  ideaFrameId String? // Optional link to specific idea

  // Search info
  provider  String // "serpapi_patents", "serpapi_scholar", "google_patents", etc.
  query     String @db.Text
  queryHash String // For deduplication/caching

  // Raw response
  rawJson Json // Raw API response

  // Parsed results
  parsedJson  Json? // Normalized results
  resultCount Int   @default(0)

  // Relevance assessment
  relevanceNotes String? @db.Text

  createdAt DateTime @default(now())

  // Relations
  session   IdeationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  ideaFrame IdeaFrame?      @relation(fields: [ideaFrameId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([queryHash])
  @@index([ideaFrameId])
  @@map("evidence_results")
}

// Ideation search cache (cost control)
model IdeationSearchCache {
  id         String   @id @default(cuid())
  cacheKey   String   @unique // Normalized query hash
  provider   String // "serpapi_patents", "serpapi_scholar"
  resultJson Json // Cached results
  hitCount   Int      @default(1)
  createdAt  DateTime @default(now())
  expiresAt  DateTime // Cache expiration

  @@index([cacheKey])
  @@index([expiresAt])
  @@map("ideation_search_cache")
}

// Ideation session history (audit trail)
model IdeationHistory {
  id        String @id @default(cuid())
  sessionId String

  // Action tracking
  action String // SEED_SUBMITTED, CLASSIFIED, NODE_EXPANDED, IDEA_GENERATED, etc.
  stage  String? // Which stage this occurred in

  // Data
  inputJson  Json? // What was sent
  outputJson Json? // What was received

  // Metadata
  userId     String
  tokensUsed Int?
  modelUsed  String?
  durationMs Int?

  timestamp DateTime @default(now())

  // Relations
  session IdeationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, action])
  @@map("ideation_history")
}

// ============================================================================
// TRIAL INVITE CAMPAIGN SYSTEM
// ============================================================================

enum TrialCampaignStatus {
  DRAFT // Campaign created but not active
  ACTIVE // Accepting invites, sending emails
  PAUSED // Temporarily paused
  COMPLETED // Campaign ended
  ARCHIVED // Archived for reference
}

enum TrialInviteStatus {
  PENDING // Uploaded but not sent
  SCHEDULED // Scheduled for future send
  SENDING // Currently being sent
  SENT // Email sent successfully
  DELIVERED // Confirmed delivered (via webhook)
  OPENED // Email opened (tracking pixel)
  CLICKED // Invite link clicked
  SIGNED_UP // User completed registration
  BOUNCED // Email bounced
  FAILED // Failed to send
  UNSUBSCRIBED // User unsubscribed
  EXPIRED // Invite expired without action
}

// Campaign groups invites for better organization and tracking
model TrialCampaign {
  id       String @id @default(cuid())
  tenantId String // Usually PLATFORM tenant for super admin

  // Campaign details
  name        String
  description String?             @db.Text
  status      TrialCampaignStatus @default(DRAFT)

  // Email template settings
  emailSubject  String  @default("You're Invited to Try Our Patent Platform")
  emailTemplate String? @db.Text // Custom HTML template (uses default if null)
  senderName    String  @default("Patent Platform Team")
  replyToEmail  String?

  // Campaign settings
  trialDurationDays Int     @default(14) // How long trial lasts after signup
  inviteExpiryDays  Int     @default(30) // How long invite link is valid
  autoExpireInvites Boolean @default(true)

  // ATI Token settings
  trialAtiTokenId String? // Link to a specific trial ATI token (optional)
  maxSignups      Int? // Max total signups for this campaign

  // Trial Plan Limits (per-user limits for this campaign's trial users)
  // NULL means use the default TRIAL plan limits
  patentDraftLimit    Int? // Max patents a trial user can draft
  noveltySearchLimit  Int? // Max novelty searches
  ideationRunLimit    Int? // Max ideation runs
  priorArtSearchLimit Int? // Max prior art searches
  diagramLimit        Int? // Max diagram generations

  // Token budget for trial users (optional)
  totalTokenBudget Int? // Max total tokens for all features combined

  // Scheduling
  defaultSendTime String? // Default time to send scheduled emails (HH:MM format)
  timezone        String  @default("UTC")

  // Stats (denormalized for quick access)
  totalInvites   Int @default(0)
  sentCount      Int @default(0)
  deliveredCount Int @default(0)
  openedCount    Int @default(0)
  clickedCount   Int @default(0)
  signedUpCount  Int @default(0)
  bouncedCount   Int @default(0)

  // Metadata
  createdBy String // Super admin who created
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invites TrialInvite[]

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("trial_campaigns")
}

// Individual trial invite records
model TrialInvite {
  id         String @id @default(cuid())
  campaignId String

  // Recipient info
  email      String
  firstName  String?
  lastName   String?
  country    String?
  company    String?
  jobTitle   String?
  customData Json? // Any additional custom fields from CSV

  // Invite status
  status TrialInviteStatus @default(PENDING)

  // Email-locked ATI token (unique per invite)
  inviteToken     String    @unique // Unique token for this invite
  inviteTokenHash String    @unique // Hashed version for security
  allowedEmail    String // Email that can use this token (prevents sharing)
  tokenExpiresAt  DateTime?

  // Scheduling
  scheduledSendAt DateTime? // When to send (null = send immediately when triggered)
  sentAt          DateTime? // When actually sent

  // Tracking
  deliveredAt    DateTime?
  firstOpenedAt  DateTime?
  lastOpenedAt   DateTime?
  openCount      Int       @default(0)
  firstClickedAt DateTime?
  lastClickedAt  DateTime?
  clickCount     Int       @default(0)
  signedUpAt     DateTime?
  signedUpUserId String? // Link to User if they signed up
  bouncedAt      DateTime?
  bounceReason   String?
  unsubscribedAt DateTime?

  // Email provider tracking
  mailjetMessageId String? // Mailjet message ID for webhook correlation
  mailjetStatus    String? // Last status from Mailjet

  // Resend tracking
  resendCount  Int       @default(0)
  lastResendAt DateTime?
  resendReason String?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  campaign TrialCampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  events   TrialInviteEvent[]

  @@unique([campaignId, email]) // One invite per email per campaign
  @@index([campaignId])
  @@index([email])
  @@index([status])
  @@index([scheduledSendAt])
  @@index([inviteToken])
  @@index([mailjetMessageId]) // For webhook correlation lookups
  @@index([tokenExpiresAt]) // For expire job queries
  @@index([signedUpUserId]) // For user activity queries
  @@map("trial_invites")
}

// Detailed event log for each invite
model TrialInviteEvent {
  id       String @id @default(cuid())
  inviteId String

  // Event details
  eventType String // CREATED, SCHEDULED, SENT, DELIVERED, OPENED, CLICKED, SIGNED_UP, BOUNCED, FAILED, RESENT, UNSUBSCRIBED
  eventData Json? // Additional event data (e.g., IP, user agent, bounce reason)

  // Source
  source String? // "mailjet_webhook", "tracking_pixel", "link_click", "signup", "manual"

  // IP tracking (for opens/clicks)
  ipAddress  String?
  userAgent  String?
  geoCountry String?
  geoCity    String?

  timestamp DateTime @default(now())

  // Relations
  invite TrialInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([inviteId])
  @@index([eventType])
  @@index([timestamp])
  @@map("trial_invite_events")
}

// Email template variations for A/B testing (future)
model TrialEmailTemplate {
  id String @id @default(cuid())

  name        String
  description String?
  subject     String
  htmlContent String  @db.Text
  textContent String? @db.Text // Plain text fallback

  // Variables available: {{firstName}}, {{lastName}}, {{inviteLink}}, {{expiryDate}}, {{companyName}}
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("trial_email_templates")
}

// Unsubscribe list (GDPR compliance)
model TrialUnsubscribe {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String?
  source    String? // Which campaign/invite triggered unsubscribe
  createdAt DateTime @default(now())

  @@index([email])
  @@map("trial_unsubscribes")
}

// ============================================================================
// RESEARCH PAPER WRITING MODELS
// ============================================================================

model PaperTypeDefinition {
  id          String  @id @default(cuid())
  code        String  @unique // e.g., "JOURNAL_ARTICLE", "CONFERENCE_PAPER"
  name        String // Display name: "Journal Article", "Conference Paper"
  description String? // Optional description of the paper type

  // Section configuration as JSON
  requiredSections Json // Array of required section keys: ["abstract", "introduction", "methodology"]
  optionalSections Json // Array of optional section keys: ["literature_review", "acknowledgments"]
  sectionOrder     Json // Ordered array of all sections: ["abstract", "introduction", ...]

  // Word limits per section as JSON object
  defaultWordLimits Json // { "abstract": 250, "introduction": 1000, "methodology": 1500 }

  // Default citation style preference
  defaultCitationStyle String? // e.g., "APA7", "IEEE", "CHICAGO"

  // Status and metadata
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0) // For UI ordering
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sessions DraftingSession[] // Sessions using this paper type
  // papers      Paper[] // Papers using this type (when Paper model is created)

  @@index([code])
  @@index([isActive])
  @@index([sortOrder])
  @@map("paper_type_definitions")
}

model CitationStyleDefinition {
  id   String @id @default(cuid())
  code String @unique // e.g., "APA7", "IEEE", "CHICAGO"
  name String // Display name: "APA 7th Edition", "IEEE"

  // In-text citation format template
  // Examples: "(Author, Year)" for APA, "[1]" for IEEE
  inTextFormatTemplate String

  // Bibliography format rules as JSON
  // Complex rules for different source types (book, journal, website, etc.)
  bibliographyRules Json

  // Sorting rules for bibliography
  // "alphabetical" or "order_of_appearance"
  bibliographySortOrder String @default("alphabetical")

  // Whether to use Ibid. or short titles for repeated citations (Chicago style)
  supportsShortTitles Boolean @default(false)

  // Maximum number of authors before "et al."
  maxAuthorsBeforeEtAl Int @default(3)

  // Status and metadata
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0) // For UI ordering
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sessions DraftingSession[] // Sessions using this citation style
  // papers      Paper[]
  venues   PublicationVenue[]

  @@index([code])
  @@index([isActive])
  @@index([sortOrder])
  @@map("citation_style_definitions")
}

model PublicationVenue {
  id   String @id @default(cuid())
  code String @unique // e.g., "NATURE", "IEEE_TRANS_SOFT_ENG", "ACM_CONFERENCE"
  name String // Display name: "Nature", "IEEE Transactions on Software Engineering"

  // Venue classification
  venueType VenueType // journal, conference, book_publisher

  // Associated citation style (required)
  citationStyleId String
  citationStyle   CitationStyleDefinition @relation(fields: [citationStyleId], references: [id])

  // Paper type restrictions (optional - which paper types this venue accepts)
  acceptedPaperTypes String[] // Array of PaperTypeDefinition codes, empty means all accepted

  // Section requirements override (JSON)
  sectionOverrides Json? // Override default section requirements for specific venues

  // Word limit overrides (JSON)
  wordLimitOverrides Json? // Override default word limits: { "abstract": 200, "introduction": 800 }

  // Formatting guidelines (JSON)
  formattingGuidelines Json? // Specific formatting rules, templates, etc.

  // Additional metadata
  impactFactor  Float? // Journal impact factor
  ranking       Int? // Alternative ranking system
  website       String? // Official website URL
  submissionUrl String? // Submission system URL

  // Status and metadata
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0) // For UI ordering
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sessions DraftingSession[] // Sessions targeting this venue
  // papers      Paper[]

  @@index([code])
  @@index([venueType])
  @@index([citationStyleId])
  @@index([isActive])
  @@index([sortOrder])
  @@map("publication_venues")
}

model ResearchTopic {
  id String @id @default(cuid())

  // Session relationship (replaces IdeaRecord.sessionId)
  sessionId String          @unique
  session   DraftingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // ============================================================================
  // BASIC INFO SEGMENT
  // ============================================================================
  title            String   // Research/paper title
  field            String?  // Research field (e.g., "Computer Science")
  subfield         String?  // Subfield/specialization
  topicDescription String?  @db.Text // Brief topic description

  // ============================================================================
  // RESEARCH QUESTION SEGMENT
  // ============================================================================
  researchQuestion  String   @db.Text // Main research question (required)
  subQuestions      String[] // Sub-questions to investigate
  problemStatement  String?  @db.Text // Problem being addressed
  researchGaps      String?  @db.Text // Identified gaps in literature

  // ============================================================================
  // METHODOLOGY SEGMENT
  // ============================================================================
  methodology            MethodologyType // Research methodology type
  methodologyApproach    String?  @db.Text // Detailed approach description
  techniques             String[] // Research techniques to use
  methodologyJustification String? @db.Text // Why this methodology

  // ============================================================================
  // DATA & EXPERIMENTATION SEGMENT
  // ============================================================================
  datasetDescription String?  @db.Text // Description of dataset
  dataCollection     String?  @db.Text // Data collection method
  sampleSize         String?  // Expected sample size
  tools              String[] // Tools/software to use
  experiments        String?  @db.Text // Planned experiments

  // ============================================================================
  // EXPECTED OUTCOMES SEGMENT
  // ============================================================================
  hypothesis       String?  @db.Text // Research hypothesis
  expectedResults  String?  @db.Text // Expected findings
  contributionType ContributionType // Type of contribution
  novelty          String?  @db.Text // What makes this novel
  limitations      String?  @db.Text // Known limitations

  // ============================================================================
  // KEYWORDS & ABSTRACT
  // ============================================================================
  keywords      String[] // Research keywords/tags
  abstractDraft String?  @db.Text // Draft abstract/summary

  // ============================================================================
  // LLM METADATA
  // ============================================================================
  llmPromptUsed String? @db.Text // The prompt that generated this topic
  llmResponse   String? @db.Text // Raw LLM response
  llmTokensUsed Int?    // Token usage for billing/analytics

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([methodology])
  @@index([contributionType])
  @@map("research_topics")
}

// ============================================================================
// PAPER BLUEPRINT SYSTEM (Coherence by Construction)
// ============================================================================

// Paper Blueprint - Frozen plan that governs all section generation
model PaperBlueprint {
  id        String @id @default(cuid())
  sessionId String @unique
  session   DraftingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Core thesis elements (synthesized from ResearchTopic)
  thesisStatement  String  @db.Text // Single sentence central claim
  centralObjective String  @db.Text // 1-2 sentences: what the paper will achieve
  keyContributions String[] // 3-7 testable outcomes/deliverables

  // Section plan - methodology-aware structure
  // JSON array of: { sectionKey, purpose, mustCover[], mustAvoid[], wordBudget?, dependencies[] }
  sectionPlan Json

  // Terminology policy (simplified)
  // JSON object: { "preferredTerm": "definition", ... }
  preferredTerms Json?

  // Narrative arc (optional guidance)
  narrativeArc String? @db.Text // gap → approach → result → implication

  // Paper type context (for methodology-specific constraints)
  paperTypeCode   String? // e.g., "JOURNAL_ARTICLE", "REVIEW_ARTICLE"
  methodologyType String? // e.g., "QUANTITATIVE", "QUALITATIVE", "REVIEW"

  // Freeze state
  status   BlueprintStatus @default(DRAFT)
  frozenAt DateTime?

  // Versioning
  version   Int    @default(1)
  changeLog Json?  // Array of { version, changedAt, changes[] }

  // LLM metadata
  llmPromptUsed String? @db.Text
  llmResponse   String? @db.Text
  llmTokensUsed Int?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([status])
  @@map("paper_blueprints")
}

// Paper Section - Generated content with inline memory
model PaperSection {
  id        String @id @default(cuid())
  sessionId String
  session   DraftingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Section identification
  sectionKey   String // e.g., "introduction", "methodology", "results"
  displayName  String // Human-readable name

  // Generated content
  content   String  @db.Text
  wordCount Int?

  // Inline memory (key innovation - passed to subsequent sections)
  // JSON: { keyPoints[], termsIntroduced[], mainClaims[], forwardReferences[] }
  memory Json?

  // Generation metadata
  blueprintVersion Int? // Which blueprint version was used
  promptUsed       String? @db.Text
  llmResponse      String? @db.Text
  tokensUsed       Int?

  // Status
  status    PaperSectionStatus @default(DRAFT)
  isStale   Boolean            @default(false) // Marked stale if blueprint changes

  // Versioning
  version Int @default(1)

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  generatedAt DateTime @default(now())

  @@unique([sessionId, sectionKey])
  @@index([sessionId])
  @@index([sectionKey])
  @@index([status])
  @@map("paper_sections")
}

enum BlueprintStatus {
  DRAFT // Editable, not yet frozen
  FROZEN // Locked, governs all section generation
  REVISION_PENDING // User requested changes, needs re-freeze
}

enum PaperSectionStatus {
  DRAFT // Initial generation
  REVIEWED // User has reviewed
  APPROVED // User approved final
  REGENERATING // Currently being regenerated
}

// ============================================================================
// PAPER SUPERSET SECTION SYSTEM (Admin-Configurable Prompts)
// Mirrors SupersetSection/CountrySectionPrompt pattern for papers
// ============================================================================

// Base section definitions for academic papers (like SupersetSection for patents)
model PaperSupersetSection {
  id           String   @id @default(cuid())
  sectionKey   String   @unique @map("section_key") // e.g., "abstract", "introduction", "methodology"
  displayOrder Int      @map("display_order") // Order in the drafting flow
  label        String // Display label: "Abstract", "Introduction", etc.
  description  String?  @db.Text // Description of what this section contains
  instruction  String   @db.Text // Base prompt instruction for LLM
  constraints  Json     @default("{}") // { wordLimit, citationRequirements, tenseRequirements, styleRequirements }
  isRequired   Boolean  @default(true) @map("is_required") // Default required status
  isActive     Boolean  @default(true) @map("is_active") // Can be disabled without deleting

  // Context injection flags for papers
  requiresBlueprint        Boolean @default(true) @map("requires_blueprint") // Inject blueprint context
  requiresPreviousSections Boolean @default(true) @map("requires_previous_sections") // Inject previous section memory
  requiresCitations        Boolean @default(false) @map("requires_citations") // Inject citation list

  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  paperTypePrompts PaperTypeSectionPrompt[]

  @@index([displayOrder])
  @@index([isActive])
  @@map("paper_superset_sections")
}

// Paper-type-specific prompt overrides (like CountrySectionPrompt for patents)
// New paper types automatically inherit base prompts from PaperSupersetSection
model PaperTypeSectionPrompt {
  id              String                       @id @default(cuid())
  paperTypeCode   String                       @map("paper_type_code") // e.g., "JOURNAL_ARTICLE", "CONFERENCE_PAPER"
  sectionKey      String                       @map("section_key") // canonical key: "abstract", "introduction", etc.
  instruction     String                       @db.Text // Override instruction (merged with base prompt)
  constraints     Json                         @default("{}") // Override constraints (merged with base)
  additions       Json?                        @default("[]") // Array of additional guidance strings
  version         Int                          @default(1)
  status          PaperTypeSectionPromptStatus @default(ACTIVE)
  createdBy       String?                      @map("created_by")
  updatedBy       String?                      @map("updated_by")
  createdAt       DateTime                     @default(now()) @map("created_at")
  updatedAt       DateTime                     @updatedAt @map("updated_at")

  // Relations
  supersetSection PaperSupersetSection          @relation(fields: [sectionKey], references: [sectionKey])
  history         PaperTypeSectionPromptHistory[]

  @@unique([paperTypeCode, sectionKey], name: "paper_type_section_unique")
  @@index([paperTypeCode])
  @@index([sectionKey])
  @@index([status])
  @@map("paper_type_section_prompts")
}

enum PaperTypeSectionPromptStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

// Audit trail for paper prompt changes
model PaperTypeSectionPromptHistory {
  id            String   @id @default(cuid())
  promptId      String   @map("prompt_id")
  paperTypeCode String   @map("paper_type_code")
  sectionKey    String   @map("section_key")
  instruction   String   @db.Text
  constraints   Json     @default("{}")
  additions     Json?    @default("[]")
  version       Int
  changeType    String   @map("change_type") // CREATE, UPDATE, ARCHIVE, RESTORE
  changeReason  String?  @map("change_reason")
  changedBy     String?  @map("changed_by")
  changedAt     DateTime @default(now()) @map("changed_at")

  // Relation to parent prompt
  prompt PaperTypeSectionPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@index([paperTypeCode, sectionKey])
  @@map("paper_type_section_prompt_history")
}

model Citation {
  id String @id @default(cuid())

  // Session relationship
  sessionId String
  session   DraftingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Source classification
  sourceType CitationSourceType

  // Core bibliographic fields
  title     String
  authors   String[] // Array of author names
  year      Int?
  venue     String? // Journal name, conference name, book title, etc.
  volume    String?
  issue     String?
  pages     String?
  doi       String?
  url       String?
  isbn      String?
  publisher String?
  edition   String?
  abstract  String?  @db.Text // Full abstract from source

  // Citation management
  citationKey String // Auto-generated unique key (e.g., "Smith2023a")
  bibtex      String? // Full BibTeX representation

  // Import metadata
  importSource CitationImportSource @default(MANUAL)
  importDate   DateTime             @default(now())

  // User annotations
  notes String?
  tags  String[] @default([]) // User-defined tags for organization

  // AI-generated citation metadata for section generation
  // Contains: keyContribution, keyFindings, methodologicalApproach, 
  // relevanceToResearch, limitationsOrGaps, usage (intro/litReview/methodology/comparison)
  aiMeta Json?

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  usages CitationUsage[]

  @@unique([sessionId, doi]) // Prevent duplicate DOIs per session
  @@index([sessionId])
  @@index([citationKey])
  @@index([doi])
  @@index([sourceType])
  @@index([importSource])
  @@index([isActive])
  @@map("citations")
}

model CitationUsage {
  id String @id @default(cuid())

  // Citation relationship
  citationId String
  citation   Citation @relation(fields: [citationId], references: [id], onDelete: Cascade)

  // Usage context
  sectionKey     String // Section where citation is used (e.g., "introduction", "literature_review")
  position       Int? // Position in the text (optional)
  contextSnippet String? // Snippet of surrounding text

  // Citation format used
  inTextFormat String // The actual formatted citation text used (e.g., "(Smith et al., 2023)")

  // Blueprint dimension mapping (Part B of SRS - optional, populated by citation mapping service)
  dimension       String?                    // The mustCover dimension this citation supports
  remark          String?     @db.Text       // LLM-generated remark explaining support for the dimension
  confidence      DimensionMappingConfidence? // Confidence level of the mapping
  mappedAt        DateTime?                  // When the mapping was generated
  mappingSource   String?     @default("auto") // "auto" for LLM-generated, "manual" for user-set

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([citationId])
  @@index([sectionKey])
  @@index([dimension])
  @@map("citation_usages")
}

// Confidence level for citation-to-dimension mappings
enum DimensionMappingConfidence {
  HIGH    // Clear, direct support for the dimension
  MEDIUM  // Reasonable support, some interpretation required
  LOW     // Weak/tangential support
}

enum VenueType {
  JOURNAL
  CONFERENCE
  BOOK_PUBLISHER
}

enum MethodologyType {
  QUALITATIVE
  QUANTITATIVE
  MIXED_METHODS
  THEORETICAL
  CASE_STUDY
  ACTION_RESEARCH
  EXPERIMENTAL
  SURVEY
  OTHER
}

enum ContributionType {
  THEORETICAL // New theory or theoretical framework
  EMPIRICAL // New empirical findings
  METHODOLOGICAL // New methods or methodological improvements
  APPLIED // Practical applications or solutions
  REVIEW // Synthesis of existing knowledge
  CONCEPTUAL // Conceptual models or frameworks
}

enum CitationSourceType {
  JOURNAL_ARTICLE
  CONFERENCE_PAPER
  BOOK
  BOOK_CHAPTER
  THESIS
  WORKING_PAPER
  REPORT
  WEBSITE
  PATENT
  OTHER
}

enum CitationImportSource {
  MANUAL // User manually entered
  DOI_LOOKUP // Imported via DOI
  SCHOLAR_SEARCH // From Google Scholar
  CROSSREF_API // From CrossRef API
  BIBTEX_IMPORT // From BibTeX file/string
  SEMANTIC_SCHOLAR // From Semantic Scholar API
  OPENALEX // From OpenAlex API
  MENDELEY_IMPORT // From Mendeley export
  ZOTERO_IMPORT // From Zotero export (RIS/BibTeX)
  ENDNOTE_IMPORT // From EndNote export (RIS/XML)
  RIS_IMPORT // From RIS format file
  LIBRARY_IMPORT // From user's reference library
}

enum LiteratureReviewStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// ============================================================================
// USER REFERENCE LIBRARY (Mendeley-like personal library)
// ============================================================================

// Literature Search Run - Persists search results with AI analysis
model LiteratureSearchRun {
  id        String @id @default(cuid())
  sessionId String

  // Search parameters
  query    String
  sources  String[] // Which providers were searched
  yearFrom Int?
  yearTo   Int?

  // Search results (full result objects)
  results Json // Array of SearchResult objects

  // AI Analysis (populated when user clicks "Help Me Find Relevant")
  aiAnalysis       Json? // { suggestions: [{ paperId, isRelevant, score, reasoning }] }
  aiAnalyzedAt     DateTime?
  aiModelUsed      String?
  aiTokensUsed     Int?
  researchQuestion String? // The research question used for analysis

  // Link to search strategy query (if executed from strategy)
  strategyQueryId String?
  strategyQuery   CitationSearchQuery? @relation(fields: [strategyQueryId], references: [id])

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  session DraftingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@index([strategyQueryId])
  @@map("literature_search_runs")
}

// ============================================================================
// CITATION SEARCH STRATEGY
// Systematic search query generation for comprehensive literature coverage
// ============================================================================

model CitationSearchStrategy {
  id        String @id @default(cuid())
  sessionId String @unique

  // Source information for generation
  paperTitle       String?
  paperAbstract    String?  @db.Text
  keywords         String[]
  researchFocus    String?  @db.Text // Main focus/objective of the research

  // Generation metadata
  generatedAt DateTime  @default(now())
  aiModelUsed String?
  
  // Strategy overview
  summary          String?  @db.Text // AI-generated overview of the search strategy
  estimatedPapers  Int?     // Estimated total papers to find
  
  // Status
  status           SearchStrategyStatus @default(DRAFT)
  completedAt      DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  session DraftingSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  queries CitationSearchQuery[]

  @@index([sessionId])
  @@index([status])
  @@map("citation_search_strategies")
}

model CitationSearchQuery {
  id         String @id @default(cuid())
  strategyId String
  
  // Query details
  queryText    String   // The actual search query
  category     SearchQueryCategory
  description  String   // Why this query is included / what it covers
  priority     Int      // Execution order (1 = first)
  
  // Search suggestions
  suggestedSources   String[]  // Recommended sources for this query
  suggestedYearFrom  Int?      // Suggested year range
  suggestedYearTo    Int?
  suggestedFilters   Json?     // Additional filter suggestions
  
  // Execution status
  status        SearchQueryStatus @default(PENDING)
  searchedAt    DateTime?
  resultsCount  Int?              // Total results from search
  importedCount Int?              // Papers imported from this query
  
  // Notes
  userNotes     String?  @db.Text
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  strategy   CitationSearchStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  searchRuns LiteratureSearchRun[]

  @@index([strategyId])
  @@index([category])
  @@index([status])
  @@index([priority])
  @@map("citation_search_queries")
}

enum SearchStrategyStatus {
  DRAFT       // Being generated
  READY       // Ready to use
  IN_PROGRESS // Some queries executed
  COMPLETED   // All queries done
}

enum SearchQueryCategory {
  CORE_CONCEPTS         // Main topic keywords
  DOMAIN_APPLICATION    // Field-specific papers
  METHODOLOGY           // Methods and techniques
  THEORETICAL_FOUNDATION // Foundational/seminal works
  SURVEYS_REVIEWS       // Existing reviews and surveys
  COMPETING_APPROACHES  // Alternative methods/baselines
  RECENT_ADVANCES       // Latest papers
  GAP_IDENTIFICATION    // Papers highlighting gaps
  CUSTOM                // User-added queries
}

enum SearchQueryStatus {
  PENDING     // Not yet searched
  SEARCHING   // Currently searching
  SEARCHED    // Search completed, reviewing results
  COMPLETED   // Done - papers imported
  SKIPPED     // User chose to skip this query
}

model ReferenceLibrary {
  id     String @id @default(cuid())
  userId String @map("user_id")

  // Core bibliographic fields (same as Citation)
  title     String
  authors   String[] // Array of author names
  year      Int?
  venue     String? // Journal name, conference name, book title, etc.
  volume    String?
  issue     String?
  pages     String?
  doi       String?
  url       String?
  isbn      String?
  publisher String?
  edition   String?
  abstract  String?  @db.Text // Full abstract

  // Source classification
  sourceType CitationSourceType @default(OTHER)

  // Reference management
  citationKey String? // Auto-generated unique key (e.g., "Smith2023a")
  bibtex      String? @db.Text // Full BibTeX representation

  // Import metadata
  importSource CitationImportSource @default(MANUAL)
  importDate   DateTime             @default(now())
  externalId   String? // External reference ID (e.g., Mendeley UUID)

  // User annotations
  notes String?  @db.Text
  tags  String[] @default([]) // User-defined tags for organization

  // File attachments (PDF paths/URLs)
  pdfUrl String?

  // Reading status
  isRead     Boolean @default(false)
  isFavorite Boolean @default(false)

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  collections ReferenceCollectionItem[]

  @@unique([userId, doi]) // Prevent duplicate DOIs per user
  @@index([userId])
  @@index([doi])
  @@index([sourceType])
  @@index([isFavorite])
  @@index([isRead])
  @@map("reference_library")
}

model ReferenceCollection {
  id     String @id @default(cuid())
  userId String @map("user_id")

  // Collection metadata
  name        String
  description String?
  color       String? // Hex color for UI display
  icon        String? // Icon name for UI display

  // Visibility
  isDefault Boolean @default(false) // "All References" collection
  isShared  Boolean @default(false) // Can be shared with collaborators

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ReferenceCollectionItem[]

  @@unique([userId, name]) // Unique collection names per user
  @@index([userId])
  @@map("reference_collections")
}

model ReferenceCollectionItem {
  id           String @id @default(cuid())
  collectionId String @map("collection_id")
  referenceId  String @map("reference_id")

  // Order within collection
  sortOrder Int @default(0)

  // Additional per-collection notes
  collectionNotes String?

  // Timestamps
  addedAt DateTime @default(now())

  // Relations
  collection ReferenceCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  reference  ReferenceLibrary    @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@unique([collectionId, referenceId]) // Prevent duplicates in same collection
  @@index([collectionId])
  @@index([referenceId])
  @@map("reference_collection_items")
}
