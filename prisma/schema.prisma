generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:123@localhost:5432/papsi"
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  SUPER_ADMIN
  SUPER_ADMIN_VIEWER
  OWNER
  ADMIN
  MANAGER
  ANALYST
  VIEWER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum TenantType {
  INDIVIDUAL // Personal tenants for solo users (can have multi-role)
  ENTERPRISE // Enterprise tenants (strict role separation)
}

// Service types for access control
enum ServiceType {
  PATENT_DRAFTING
  NOVELTY_SEARCH
  PRIOR_ART_SEARCH
  IDEA_BANK
  PERSONA_SYNC
  DIAGRAM_GENERATION
  PATENT_REVIEW // AI-powered patent draft review (Pro tier)
  IDEATION // Mind-map patent ideation engine
}

// Team roles within a team
enum TeamRole {
  LEAD // Team lead - can manage team settings
  MEMBER // Regular member
}

enum ATITokenStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ISSUED
  REVOKED
  EXPIRED
  USED_UP
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  atiId     String       @unique
  type      TenantType   @default(ENTERPRISE) // Default to enterprise for existing tenants
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users     User[]
  atiTokens ATIToken[]
  auditLogs AuditLog[]

  // Metering relations
  tenantPlans            TenantPlan[]
  usageReservations      UsageReservation[]
  usageMeters            UsageMeter[]
  usageLogs              UsageLog[]
  quotaAlerts            QuotaAlert[]
  patentDraftingUsage    PatentDraftingUsage[]
  serviceCompletionUsage ServiceCompletionUsage[]
  diagramGenerationUsage DiagramGenerationUsage[]
  sketchGenerationUsage  SketchGenerationUsage[]

  // Drafting relations
  draftingSessions DraftingSession[]

  // Idea Bank relations
  ideaBankIdeas IdeaBankIdea[]

  // Style Profile relations
  styleProfiles     StyleProfile[]
  styleTrainingJobs StyleTrainingJob[]
  documents         Document[]

  // Organizational structure
  teams           Team[]
  writingSamples  WritingSample[]
  writingPersonas WritingPersona[]
  
  // Paper Writing (academic papers)
  paperWritingSamples  PaperWritingSample[]
  paperWritingPersonas PaperWritingPersona[]

  // Style configuration overrides
  userDiagramStyles UserDiagramStyle[]
  userExportStyles  UserExportStyle[]

  // Ideation relations
  ideationSessions IdeationSession[]

  // Trial campaign relations
  trialCampaigns TrialCampaign[]

  @@map("tenants")
}

enum OAuthProvider {
  GOOGLE
  FACEBOOK
  LINKEDIN
  TWITTER
}

model User {
  id                       String     @id @default(cuid())
  tenantId                 String?
  signupAtiTokenId         String? // Track which ATI token was used for signup
  email                    String     @unique
  passwordHash             String?
  name                     String?
  firstName                String?
  lastName                 String?
  roles                    UserRole[] @default([ANALYST])
  status                   UserStatus @default(ACTIVE)
  emailVerified            Boolean    @default(false)
  noveltySearchesCompleted Int        @default(0) // Track successful novelty searches

  // Social login fields
  oauthProvider   OAuthProvider?
  oauthProviderId String?
  oauthProfile    Json? // Store additional OAuth profile data

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                  Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  signupAtiToken          ATIToken?               @relation("SignupATIToken", fields: [signupAtiTokenId], references: [id])
  projects                Project[]
  collaborations          ProjectCollaborator[]
  patents                 Patent[]
  annexureVersions        AnnexureVersion[]
  auditLogs               AuditLog[]
  usageLogs               UsageLog[]
  createdPriorArtBundles  PriorArtSearchBundle[]  @relation("PriorArtBundleCreator")
  approvedPriorArtBundles PriorArtSearchBundle[]  @relation("PriorArtBundleApprover")
  priorArtHistory         PriorArtSearchHistory[]
  priorArtRuns            PriorArtRun[]
  credits                 UserCredit?
  noveltyAssessments      NoveltyAssessmentRun[]
  noveltySearchRuns       NoveltySearchRun[]
  draftingSessions        DraftingSession[]
  draftingHistory         DraftingHistory[]

  // Reference Library (Mendeley-like personal library)
  referenceLibrary     ReferenceLibrary[]
  referenceCollections ReferenceCollection[]

  // Auth tokens
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]

  // Idea Bank relations
  createdIdeaBankIdeas IdeaBankIdea[]        @relation("IdeaBankIdeaCreator")
  ideaBankReservations IdeaBankReservation[]
  ideaBankHistory      IdeaBankHistory[]

  // Style Profile relations
  styleProfiles       StyleProfile[]     @relation("StyleProfileCreator")
  lockedStyleProfiles StyleProfile[]     @relation("StyleProfileLocker")
  ownedStyleProfiles  StyleProfile[]     @relation("StyleProfileUser")
  styleTrainingJobs   StyleTrainingJob[]
  documents           Document[]

  // Country Profile relations
  createdCountryProfiles CountryProfile[] @relation("CountryProfileCreator")
  updatedCountryProfiles CountryProfile[] @relation("CountryProfileUpdater")

  // Writing Samples for example-based style mimicry
  writingSamples  WritingSample[]
  createdPersonas WritingPersona[] @relation("PersonaCreator")
  
  // Paper Writing Samples for academic style mimicry
  paperWritingSamples  PaperWritingSample[]
  createdPaperPersonas PaperWritingPersona[] @relation("PaperPersonaCreator")

  // Team membership and service quotas
  teamMemberships TeamMember[]
  serviceQuotas   UserServiceQuota[]

  // Style configuration overrides
  userDiagramStyles       UserDiagramStyle[]
  userExportStyles        UserExportStyle[]
  userValidationOverrides UserValidationOverride[]

  // Config import tracking
  configImports CountryConfigImport[] @relation("ConfigImporter")

  // Service completion tracking
  serviceCompletionUsage ServiceCompletionUsage[]

  // Ideation relations
  ideationSessions IdeationSession[]

  // User-level section instructions (persistent across sessions)
  sectionInstructions UserSectionInstruction[]

  @@map("users")
}

// Email verification tokens for new users
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

// Password reset tokens
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// Refresh tokens for JWT rotation (stored for revocation capability)
model RefreshToken {
  id            String    @id @default(cuid())
  userId        String
  tokenHash     String    @unique // SHA256 hash of the token
  familyId      String // Token family for rotation detection
  expiresAt     DateTime
  isRevoked     Boolean   @default(false)
  revokedAt     DateTime?
  revokedReason String? // "logout", "rotation", "security", "admin"
  userAgent     String? // Browser/device info for session management
  ipAddress     String? // IP address at token creation
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model ATIToken {
  id             String         @id @default(cuid())
  tenantId       String?
  tokenHash      String
  rawToken       String? // Encrypted raw token for revelation (temporary)
  rawTokenExpiry DateTime? // When raw token can no longer be revealed
  fingerprint    String
  status         ATITokenStatus @default(ISSUED)
  expiresAt      DateTime?
  maxUses        Int?
  usageCount     Int            @default(0)
  planTier       String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Explicit role and team assignment for new users
  assignedRole   UserRole? // Explicit role for users who sign up with this token
  assignedTeamId String? // Team to auto-add user to on signup

  tenant       Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  signupUsers  User[]  @relation("SignupATIToken")
  assignedTeam Team?   @relation("ATITokenTeam", fields: [assignedTeamId], references: [id], onDelete: SetNull)

  @@map("ati_tokens")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  tenantId    String?
  action      String
  resource    String
  ip          String?
  meta        Json?
  createdAt   DateTime @default(now())

  actor  User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// ============================================================================
// ORGANIZATIONAL STRUCTURE: Teams and Access Control
// ============================================================================

// Team within a tenant organization
model Team {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isDefault   Boolean  @default(false) // Default team for new users (if set)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String? // User ID who created the team

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members         TeamMember[]
  serviceAccess   TeamServiceAccess[]
  invitedByTokens ATIToken[]          @relation("ATITokenTeam")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("teams")
}

// Team membership
model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

// Team-level service access control
model TeamServiceAccess {
  id          String      @id @default(cuid())
  teamId      String
  serviceType ServiceType
  isEnabled   Boolean     @default(true)

  // Optional quotas at team level (overrides tenant plan if set)
  monthlyQuota Int? // NULL = use tenant plan quota
  dailyQuota   Int? // NULL = use tenant plan quota

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, serviceType])
  @@map("team_service_access")
}

// User-level service quota overrides (most granular level)
model UserServiceQuota {
  id          String      @id @default(cuid())
  userId      String
  serviceType ServiceType
  isEnabled   Boolean     @default(true)

  // Optional quotas at user level (overrides team quota if set)
  monthlyQuota Int? // NULL = use team/tenant quota
  dailyQuota   Int? // NULL = use team/tenant quota

  // Usage tracking
  currentMonthUsage Int      @default(0)
  currentDayUsage   Int      @default(0)
  lastResetDate     DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceType])
  @@map("user_service_quotas")
}

model Project {
  id                String                @id @default(cuid())
  name              String
  userId            String
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  applicantProfile  ApplicantProfile?
  collaborators     ProjectCollaborator[]
  patents           Patent[]
  noveltySearchRuns NoveltySearchRun[]
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model ApplicantProfile {
  id                         String            @id @default(cuid())
  projectId                  String            @unique
  applicantLegalName         String
  applicantCategory          ApplicantCategory
  applicantAddressLine1      String
  applicantAddressLine2      String?
  applicantCity              String
  applicantState             String
  applicantCountryCode       String
  applicantPostalCode        String
  correspondenceName         String
  correspondenceEmail        String
  correspondencePhone        String
  correspondenceAddressLine1 String
  correspondenceAddressLine2 String?
  correspondenceCity         String
  correspondenceState        String
  correspondenceCountryCode  String
  correspondencePostalCode   String
  useAgent                   Boolean           @default(false)
  agentName                  String?
  agentRegistrationNo        String?
  agentEmail                 String?
  agentPhone                 String?
  agentAddressLine1          String?
  agentAddressLine2          String?
  agentCity                  String?
  agentState                 String?
  agentCountryCode           String?
  agentPostalCode            String?
  defaultJurisdiction        Jurisdiction
  defaultRoute               FilingRoute
  defaultLanguage            String            @default("EN")
  defaultEntityStatusIn      EntityStatus
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  project                    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("applicant_profiles")
}

model ProjectCollaborator {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("collaborator") // owner, collaborator, viewer
  addedBy   String // userId of who added this collaborator
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_collaborators")
}

enum ApplicantCategory {
  natural_person
  small_entity
  startup
  others
}

enum Jurisdiction {
  IN
  PCT
  US
  EP
}

enum FilingRoute {
  national
  pct_international
  pct_national
}

enum EntityStatus {
  startup
  small_entity
  university
  regular
}

enum PlanStatus {
  ACTIVE
  INACTIVE
  DEPRECATED
}

enum FeatureCode {
  PRIOR_ART_SEARCH
  PATENT_DRAFTING
  DIAGRAM_GENERATION
  IDEA_BANK
  PERSONA_SYNC
  PATENT_REVIEW // AI-powered patent draft review (Pro tier)
  IDEATION // Mind-map patent ideation engine
  PAPER_DRAFTING // Academic paper drafting (all paper types)
  SEARCH_STRATEGY // AI-powered systematic search query generation (Pro tier)
}

enum TaskCode {
  LLM1_PRIOR_ART
  LLM2_DRAFT
  LLM3_DIAGRAM
  LLM4_NOVELTY_SCREEN
  LLM5_NOVELTY_ASSESS
  LLM6_REPORT_GENERATION
  LLM1_CLAIM_REFINEMENT
  IDEA_BANK_ACCESS
  IDEA_BANK_RESERVE
  IDEA_BANK_EDIT
  PERSONA_SYNC_LEARN
  // Ideation tasks
  IDEATION_NORMALIZE // Seed normalization
  IDEATION_CLASSIFY // Classification
  IDEATION_CONTRADICTION_MAPPING // Stage 2.5: Map contradictions to TRIZ principles
  IDEATION_EXPAND // Dimension expansion
  IDEATION_OBVIOUSNESS_FILTER // Stage 3.5: Check combination novelty before generation
  IDEATION_GENERATE // Idea frame generation
  IDEATION_NOVELTY // Novelty gate reasoning
  // Paper writing tasks
  LITERATURE_RELEVANCE // AI-assisted literature relevance analysis
  SEARCH_STRATEGY_GEN // AI-powered search strategy generation (Pro tier)
}

enum ModelClass {
  BASE_S
  BASE_M
  PRO_M
  PRO_L
  ADVANCED
}

model Patent {
  id                 String                 @id @default(cuid())
  projectId          String
  title              String
  createdBy          String
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  annexureVersions   AnnexureVersion[]
  jobs               Job[]
  priorArtBundles    PriorArtSearchBundle[]
  noveltyAssessments NoveltyAssessmentRun[]
  noveltySearchRuns  NoveltySearchRun[]
  draftingSessions   DraftingSession[]
  sketchRecords      SketchRecord[]

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])

  @@map("patents")
}

model AnnexureVersion {
  id        String   @id @default(cuid())
  patentId  String
  rev       Int      @default(1)
  html      String
  textPlain String
  createdBy String
  createdAt DateTime @default(now())

  patent  Patent @relation(fields: [patentId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [createdBy], references: [id])

  @@map("annexure_versions")
}

enum JobType {
  DRAFTING
  PRIOR_ART
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model Job {
  id            String    @id @default(cuid())
  patentId      String
  type          JobType
  status        JobStatus @default(QUEUED)
  config        Json? // JSON configuration for the job
  resultSummary Json? // JSON result summary
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patent Patent @relation(fields: [patentId], references: [id], onDelete: Cascade)

  @@map("jobs")
}

model TokenNotification {
  id               String   @id @default(cuid())
  tokenId          String
  userId           String
  notificationType String // "7_days", "3_days", "1_day", "expired"
  sentAt           DateTime @default(now())
  deliveryMethod   String // "email"
  status           String // "sent", "delivered", "failed"
  emailSent        Boolean  @default(false)

  @@unique([tokenId, userId, notificationType])
  @@map("token_notifications")
}

// === METERING SYSTEM MODELS ===

model Plan {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  cycle     String // e.g., "MONTHLY"
  status    PlanStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenantPlans       TenantPlan[]
  planFeatures      PlanFeature[]
  planLLMAccess     PlanLLMAccess[]
  policyRules       PolicyRule[]
  stageModelConfigs PlanStageModelConfig[]
  taskModelConfigs  PlanTaskModelConfig[]

  @@map("plans")
}

model TenantPlan {
  id            String    @id @default(cuid())
  tenantId      String
  planId        String
  effectiveFrom DateTime
  expiresAt     DateTime?
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])

  @@unique([tenantId, planId, effectiveFrom])
  @@map("tenant_plans")
}

model Feature {
  id   String      @id @default(cuid())
  code FeatureCode @unique
  name String
  unit String // e.g., "calls", "tokens"

  planFeatures PlanFeature[]
  linkedTasks  Task[]
  usageMeters  UsageMeter[]
  usageLogs    UsageLog[]

  @@map("features")
}

model PlanFeature {
  id        String @id @default(cuid())
  planId    String
  featureId String

  // Completion-based limits (counts complete operations)
  monthlyQuota Int? // Monthly completion limit (NULL = unlimited)
  dailyQuota   Int? // Daily completion limit (NULL = unlimited)

  // Token-based limits (prevents regeneration abuse)
  monthlyTokenLimit Int? // Monthly token limit (NULL = unlimited)
  dailyTokenLimit   Int? // Daily token limit (NULL = unlimited)

  plan    Plan    @relation(fields: [planId], references: [id])
  feature Feature @relation(fields: [featureId], references: [id])

  @@unique([planId, featureId])
  @@map("plan_features")
}

model Task {
  id              String   @id @default(cuid())
  code            TaskCode @unique
  name            String
  linkedFeatureId String

  linkedFeature Feature         @relation(fields: [linkedFeatureId], references: [id])
  planLLMAccess PlanLLMAccess[]
  usageLogs     UsageLog[]

  @@map("tasks")
}

model LLMModelClass {
  id   String     @id @default(cuid())
  code ModelClass @unique
  name String

  planLLMAccess PlanLLMAccess[]

  @@map("llm_model_classes")
}

model PlanLLMAccess {
  id             String   @id @default(cuid())
  planId         String
  taskCode       TaskCode
  allowedClasses String // JSON array of ModelClass codes
  defaultClassId String // Reference to LLMModelClass

  plan         Plan          @relation(fields: [planId], references: [id])
  task         Task          @relation(fields: [taskCode], references: [code])
  defaultClass LLMModelClass @relation(fields: [defaultClassId], references: [id])

  @@unique([planId, taskCode])
  @@map("plan_llm_access")
}

model PolicyRule {
  id       String    @id @default(cuid())
  scope    String // "plan" or "tenant"
  scopeId  String // plan_id or tenant_id
  taskCode TaskCode?
  key      String // max_tokens_in, max_tokens_out, etc.
  value    Int

  plan Plan? @relation(fields: [scopeId], references: [id])

  @@unique([scope, scopeId, taskCode, key])
  @@map("policy_rules")
}

// ============================================================================
// FLEXIBLE LLM MODEL CONFIGURATION SYSTEM
// Super Admin can configure ANY model for ANY task/stage per plan
// ============================================================================

// LLM Model Registry - All available models (super admin can add/remove)
model LLMModel {
  id          String @id @default(cuid())
  code        String @unique // e.g., "gpt-4o", "claude-3.5-sonnet"
  displayName String // Human-readable name
  provider    String // "openai", "anthropic", "google", "deepseek", "groq"

  // Capabilities & Metadata
  contextWindow     Int     @default(128000) // Max context tokens
  supportsVision    Boolean @default(false)
  supportsStreaming Boolean @default(true)

  // Cost tracking (per 1M tokens, in USD cents for precision)
  inputCostPer1M  Int @default(0) // e.g., 250 = $2.50
  outputCostPer1M Int @default(0) // e.g., 1000 = $10.00

  // Status
  isActive  Boolean @default(true)
  isDefault Boolean @default(false) // System-wide fallback

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stageConfigs PlanStageModelConfig[]
  taskConfigs  PlanTaskModelConfig[]

  @@map("llm_models")
}

// Workflow Stages - All stages across all features (super admin can add)
model WorkflowStage {
  id          String  @id @default(cuid())
  code        String  @unique // e.g., "DRAFT_IDEA_ENTRY", "NOVELTY_REPORT"
  displayName String // "Idea Entry", "Report Generation"
  featureCode String // Links to feature: "PATENT_DRAFTING", "PRIOR_ART_SEARCH"
  description String?
  sortOrder   Int     @default(0) // Display order in admin UI
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stageConfigs PlanStageModelConfig[]

  @@map("workflow_stages")
}

// Plan → Stage → Model Mapping (Core flexibility table)
model PlanStageModelConfig {
  id      String @id @default(cuid())
  planId  String
  stageId String
  modelId String // Primary model for this plan+stage

  // Fallback chain (JSON array of model IDs in priority order)
  fallbackModelIds String? // e.g., '["model-id-1", "model-id-2"]'

  // Stage-specific limits (override plan defaults)
  maxTokensIn  Int?
  maxTokensOut Int?
  temperature  Float? @default(0.7)

  // Status
  isActive Boolean @default(true)
  priority Int     @default(0) // If multiple configs, higher wins

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  plan  Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  stage WorkflowStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  model LLMModel      @relation(fields: [modelId], references: [id])

  @@unique([planId, stageId])
  @@index([planId])
  @@index([stageId])
  @@map("plan_stage_model_configs")
}

// Plan → Task → Model Mapping (Backward compatible with existing TaskCode system)
model PlanTaskModelConfig {
  id       String   @id @default(cuid())
  planId   String
  taskCode TaskCode
  modelId  String // Primary model for this plan+task

  // Fallback chain
  fallbackModelIds String?

  // Task-specific limits
  maxTokensIn  Int?
  maxTokensOut Int?
  temperature  Float? @default(0.7)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan  Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  model LLMModel @relation(fields: [modelId], references: [id])

  @@unique([planId, taskCode])
  @@map("plan_task_model_configs")
}

model UsageReservation {
  id             String    @id @default(cuid())
  tenantId       String
  featureId      String?
  taskCode       TaskCode?
  reservedUnits  Int
  status         String    @default("PENDING") // PENDING, ACTIVE, RELEASED, EXPIRED
  expiresAt      DateTime
  idempotencyKey String    @unique
  createdAt      DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("usage_reservations")
}

model UsageMeter {
  id           String    @id @default(cuid())
  tenantId     String
  featureId    String?
  taskCode     TaskCode?
  periodType   String // DAILY, MONTHLY
  periodKey    String // e.g., "2024-01", "2024-01-15"
  currentUsage Int       @default(0)
  lastUpdated  DateTime  @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  feature Feature? @relation(fields: [featureId], references: [id])

  @@unique([tenantId, featureId, taskCode, periodType, periodKey])
  @@map("usage_meters")
}

// === PATENT-BASED DRAFTING QUOTA TRACKING ===
// Tracks patent drafts counted toward quota (not LLM tokens)
// A patent is counted when essential sections (description + claims) are drafted
model PatentDraftingUsage {
  id        String @id @default(cuid())
  tenantId  String
  sessionId String @unique // Each session can only be counted once
  patentId  String
  userId    String

  // Track which essential sections have been drafted
  // Once both detailedDescription AND claims are drafted, patent is counted
  hasDescription Boolean @default(false)
  hasClaims      Boolean @default(false)
  isCounted      Boolean @default(false) // True when patent is counted toward quota

  // Period tracking for quota enforcement
  countedDate  String? // YYYY-MM-DD when counted (for daily quota)
  countedMonth String? // YYYY-MM when counted (for monthly quota)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  countedAt DateTime? // When the patent was counted toward quota

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, countedDate])
  @@index([tenantId, countedMonth])
  @@index([sessionId])
  @@map("patent_drafting_usage")
}

// ============================================================================
// UNIFIED SERVICE USAGE TRACKING
// Tracks completions for all services (not just LLM tokens)
// Each service has specific completion criteria
// ============================================================================

model ServiceCompletionUsage {
  id          String      @id @default(cuid())
  tenantId    String
  userId      String
  serviceType ServiceType

  // Unique operation identifier (e.g., searchId, sessionId, diagramId)
  operationId   String
  operationType String // e.g., "novelty_search", "prior_art_search", "diagram_generation"

  // Completion tracking
  isCompleted     Boolean   @default(false) // True when operation is fully completed
  completionDate  String? // YYYY-MM-DD when completed (for daily quota)
  completionMonth String? // YYYY-MM when completed (for monthly quota)
  completedAt     DateTime?

  // Token usage for this operation (for dual-quota enforcement)
  inputTokensUsed  Int @default(0)
  outputTokensUsed Int @default(0)
  totalTokensUsed  Int @default(0)

  // Cost tracking (calculated from model prices)
  estimatedCostUsd Float @default(0)

  // Metadata
  metadata Json? // Additional service-specific data

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tenantId, serviceType, operationId])
  @@index([tenantId, serviceType, completionDate])
  @@index([tenantId, serviceType, completionMonth])
  @@index([userId, serviceType])
  @@map("service_completion_usage")
}

// Diagram Generation Usage (for granular diagram tracking)
model DiagramGenerationUsage {
  id        String @id @default(cuid())
  tenantId  String
  userId    String
  sessionId String // Drafting session
  figureNo  Int // Figure number

  // Generation tracking
  generationCount Int     @default(0) // Number of times regenerated
  isCompleted     Boolean @default(false) // True when figure is finalized

  // Token usage
  totalInputTokens  Int @default(0)
  totalOutputTokens Int @default(0)

  // Period tracking
  countedDate  String? // YYYY-MM-DD when counted
  countedMonth String? // YYYY-MM when counted
  countedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, sessionId, figureNo])
  @@index([tenantId, countedDate])
  @@index([tenantId, countedMonth])
  @@map("diagram_generation_usage")
}

// Future: Sketch Generation Usage (under Figure Planner)
model SketchGenerationUsage {
  id        String @id @default(cuid())
  tenantId  String
  userId    String
  sessionId String
  sketchId  String // Unique sketch identifier

  // Generation tracking
  generationCount Int     @default(0)
  isCompleted     Boolean @default(false)

  // Token usage
  totalInputTokens  Int @default(0)
  totalOutputTokens Int @default(0)

  // Period tracking
  countedDate  String?
  countedMonth String?
  countedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, sessionId, sketchId])
  @@index([tenantId, countedDate])
  @@map("sketch_generation_usage")
}

model UsageLog {
  id             String    @id @default(cuid())
  tenantId       String
  userId         String?
  featureId      String?
  taskCode       TaskCode?
  modelClass     String? // ModelClass code
  apiCode        String? // PATENT_OPEN, NPL_OPEN, etc.
  inputTokens    Int?
  outputTokens   Int?
  apiCalls       Int?      @default(1)
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  status         String // PENDING, COMPLETED, FAILED
  error          String?
  idempotencyKey String?
  reservationId  String?
  meta           Json?

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])
  feature Feature? @relation(fields: [featureId], references: [id])
  task    Task?    @relation(fields: [taskCode], references: [code])

  @@map("usage_logs")
}

model LLMModelPrice {
  id                    String   @id @default(cuid())
  provider              String
  modelClass            String
  inputPricePerMTokens  Float // USD per 1M input tokens
  outputPricePerMTokens Float // USD per 1M output tokens
  currency              String   @default("USD")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([provider, modelClass])
  @@map("llm_model_prices")
}

model QuotaAlert {
  id         String    @id @default(cuid())
  tenantId   String
  featureId  String?
  taskCode   TaskCode?
  alertType  String // QUOTA_80, QUOTA_100, CONCURRENCY_LIMIT
  threshold  Int
  notifiedAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("quota_alerts")
