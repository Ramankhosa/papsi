  "rules": {
    "global": {
      "paragraphNumberingRequired": false,
      "maxPagesRecommended": 100,
      "allowEquations": true,
      "allowTables": true
    },
    "abstract": {
      "wordLimit": 150,
      "noBenefitsOrAdvantages": true,
      "noClaimLanguage": true,
      "singleParagraph": true
    },
    "claims": {
      "twoPartFormPreferred": false,
      "allowMultipleDependent": true,
      "prohibitMultipleDependentOnMultipleDependent": false,
      "preferredConnectors": ["comprising"],
      "discouragedConnectors": [],
      "forbiddenPhrases": [],
      "maxIndependentClaimsBeforeExtraFee": 0,
      "maxTotalClaimsRecommended": 20,
      "allowReferenceNumeralsInClaims": true,
      "requireSupportInDescription": true,
      "unityStandard": "single_inventive_concept"
    },
    "description": {
      "requireBestModeDisclosure": true,
      "avoidClaimLanguage": true,
      "allowReferenceNumerals": true,
      "requireEmbodimentSupportForAllClaims": true,
      "industrialApplicabilitySectionRequired": false
    },
    "drawings": {
      "requiredWhenApplicable": true,
      "paperSize": "A4",
      "colorAllowed": false,
      "lineStyle": "black_and_white_solid",
      "referenceNumeralsMandatoryWhenDrawings": true,
      "minReferenceTextSizePt": 8,
      "marginTopCm": 2.5,
      "marginBottomCm": 1.0,
      "marginLeftCm": 2.5,
      "marginRightCm": 1.5
    },
    "procedural": {
      "gracePeriodMonths": 12,
      "foreignFilingLicenseRequired": false,
      "idsRequired": false,
      "priorArtDisclosureThreshold": "no_formal_ids",
      "allowProvisionalPriority": true
    },
    "language": {
      "allowedLanguages": ["en"],
      "requiresOfficialTranslation": false
    },
    "sequenceListing": {
      "requiredIfSeqDisclosed": true,
      "format": "ST.26-XML",
      "allowLateFurnishing": true,
      "lateFurnishingNotes": "Sequence listing notes",
      "affectsFilingDate": false,
      "additionalFormatsAllowedForReference": ["TXT", "PDF"]
    },
    "pageLayout": {
      "defaultPageSize": "A4",
      "allowedPageSizes": ["A4"],
      "minMarginTopCm": 2.0,
      "minMarginBottomCm": 2.0,
      "minMarginLeftCm": 2.5,
      "minMarginRightCm": 2.0,
      "recommendedFontFamily": "Times New Roman",
      "recommendedFontSizePt": 12,
      "recommendedLineSpacing": 1.5
    }
  },

  "validation": {
    "sectionChecks": {
      "title": [
        {
          "id": "title_length",
          "type": "maxChars",
          "limit": 500,
          "severity": "error",
          "message": "Title too long"
        }
      ],
      "abstract": [
        {
          "id": "abstract_limit",
          "type": "maxWords",
          "limit": 150,
          "severity": "error",
          "message": "Abstract too long"
        }
      ],
      "claims": [
        {
          "id": "claims_limit",
          "type": "maxCount",
          "limit": 20,
          "severity": "warning",
          "message": "Many claims"
        }
      ]
    },
    "crossSectionChecks": [
      {
        "id": "claims_support",
        "type": "support",
        "from": "claims",
        "mustBeSupportedBy": ["detailed_description"],
        "severity": "error",
        "message": "Claims not supported"
      },
      {
        "id": "abstract_consistency",
        "type": "consistency",
        "from": "abstract",
        "mustBeConsistentWith": ["claims"],
        "severity": "warning",
        "message": "Abstract inconsistency"
      }
    ]
  },

  "prompts": {
    "baseStyle": {
      "tone": "technical, neutral, precise",
      "voice": "impersonal_third_person",
      "avoid": [
        "marketing language",
        "unsupported advantages"
      ]
    },
    "sections": {
      "title": {
        "instruction": "Draft title",
        "constraints": [
          "Max 500 chars",
          "No trademarks"
        ]
      },
      "field": {
        "instruction": "Draft technical field",
        "constraints": [
          "1-3 sentences",
          "No advantages"
        ]
      },
      "background": {
        "instruction": "Draft background",
        "constraints": [
          "Describe prior art",
          "Avoid obviousness admissions"
        ]
      },
      "summary": {
        "instruction": "Draft summary",
        "constraints": [
          "Problem and solution",
          "Consistent with claims"
        ]
      },
      "detailed_description": {
        "instruction": "Draft description",
        "constraints": [
          "Enable reproduction",
          "Reference drawings"
        ]
      },
      "claims": {
        "instruction": "Draft claims",
        "constraints": [
          "Clear and concise",
          "Supported by description"
        ]
      },
      "abstract": {
        "instruction": "Draft abstract",
        "constraints": [
          "150 words max",
          "Single paragraph"
        ]
      }
    }
  },

  "export": {
    "documentTypes": [
      {
        "id": "spec_pdf",
        "label": "Specification PDF",
        "includesSections": [
          "title",
          "field",
          "background",
          "summary",
          "brief_drawings",
          "detailed_description",
          "claims",
          "abstract"
        ],
        "pageSize": "A4",
        "lineSpacing": 1.5,
        "fontFamily": "Times New Roman",
        "fontSizePt": 12,
        "addPageNumbers": true,
        "addParagraphNumbers": false,
        "marginTopCm": 2.0,
        "marginBottomCm": 2.0,
        "marginLeftCm": 2.5,
        "marginRightCm": 2.0
      }
    ],
    "sectionHeadings": {
      "field": "TECHNICAL FIELD",
      "background": "BACKGROUND ART",
      "summary": "SUMMARY OF THE INVENTION",
      "brief_drawings": "BRIEF DESCRIPTION OF DRAWINGS",
      "detailed_description": "DESCRIPTION OF THE INVENTION",
      "claims": "CLAIMS",
      "abstract": "ABSTRACT"
    }
  },

  "diagrams": {
    "requiredWhenApplicable": true,
    "supportedDiagramTypes": ["block", "flowchart", "schematic", "perspective_view"],
    "figureLabelFormat": "Fig. {number}",
    "autoGenerateReferenceTable": true,
    "diagramGenerationHints": {
      "block": "Use rectangles and arrows",
      "flowchart": "Use standard symbols",
      "schematic": "Show relationships clearly",
      "perspective_view": "Use for physical forms"
    }
  },

  "crossChecks": {
    "enableSemanticCrossCheck": true,
    "checkList": [
      {
        "id": "drawings_check",
        "description": "Check drawing references",
        "from": "brief_drawings",
        "mustBeExplainedIn": ["detailed_description"]
      },
      {
        "id": "claims_drawings",
        "description": "Check claims vs drawings",
        "from": "claims",
        "mustBeShownIn": ["brief_drawings"]
      }
    ]
  }
}
