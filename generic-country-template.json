  "structure": {
    "defaultVariant": "standard",
    "variants": [
      {
        "id": "standard",
        "label": "Standard Patent Application",
        "description": "Standard patent application description",
        "sections": [
          {
            "id": "title",
            "label": "Title",
            "order": 1,
            "canonicalKeys": ["title"],
            "required": true,
            "group": "header",
            "maxLengthChars": 500,
            "ui": {
              "placeholder": "Enter title",
              "helpText": "Title help text"
            }
          },
          {
            "id": "cross_reference",
            "label": "Cross-Reference",
            "order": 2,
            "canonicalKeys": ["cross_reference"],
            "required": false,
            "group": "header",
            "ui": {
              "placeholder": "Related applications",
              "helpText": "Cross-reference help"
            }
          },
          {
            "id": "field",
            "label": "Technical Field",
            "order": 3,
            "canonicalKeys": ["technical_field"],
            "required": true,
            "group": "body",
            "ui": {
              "placeholder": "Technical field",
              "helpText": "Field help text"
            }
          },
          {
            "id": "background",
            "label": "Background Art",
            "order": 4,
            "canonicalKeys": ["background"],
            "required": true,
            "group": "body",
            "ui": {
              "placeholder": "Background art",
              "helpText": "Background help"
            }
          },
          {
            "id": "summary",
            "label": "Summary",
            "order": 5,
            "canonicalKeys": ["summary_of_invention"],
            "required": true,
            "group": "body",
            "ui": {
              "placeholder": "Summary",
              "helpText": "Summary help"
            }
          },
          {
            "id": "brief_drawings",
            "label": "Brief Description of Drawings",
            "order": 6,
            "canonicalKeys": ["brief_description_of_drawings"],
            "required": false,
            "group": "body",
            "ui": {
              "placeholder": "Drawing descriptions",
              "helpText": "Drawing help"
            }
          },
          {
            "id": "detailed_description",
            "label": "Detailed Description",
            "order": 7,
            "canonicalKeys": ["detailed_description"],
            "required": true,
            "group": "body",
            "ui": {
              "placeholder": "Detailed description",
              "helpText": "Description help"
            }
          },
          {
            "id": "claims",
            "label": "Claims",
            "order": 8,
            "canonicalKeys": ["claims"],
